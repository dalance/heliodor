// Regression: LBU → BNEZ with no NOP between (load-use hazard with branch consumer).
// Tests that write-first forwarding in regfile propagates correctly.
// LBU loads 0xBE from dcache (miss), immediately followed by BNEZ.
// If forwarding works: BNEZ taken → x3 = 0xAA.
// If forwarding fails: BNEZ not taken (stale a5=0) → x3 = 0xBB.
module test_load_use_branch_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var uart_tx   : logic;
    var uart_data : logic<8>;
    var _dbg_stall: logic<8>;
    var _iptw_addr: logic<64>;
    var _iptw_req : logic;

    inst dut: heliodor_top (
        clk, rst,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_iptw_addr  : _iptw_addr    ,
        o_iptw_req   : _iptw_req     ,
        i_iptw_rdata : 64'd0         ,
        i_uart_rx_data : 8'd0        ,
        i_uart_rx_valid: 1'b0        ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
        o_uart_tx    : uart_tx       ,
        o_uart_data  : uart_data     ,
        o_dbg_stall  : _dbg_stall    ,
    );

    // Unified memory (read-only, both instruction and data ports)
    var mem: logic<32> [8192];
    initial {
        $readmemh("test/hex/load_use_branch_test.hex", mem);
    }
    assign imem_rdata = mem[imem_addr[14:2]];
    let dword_idx: logic<12> = dmem_addr[14:3];
    assign dmem_rdata = {mem[{dword_idx, 1'b1}], mem[{dword_idx, 1'b0}]};

    // x3 = result (0xAA if taken, 0xBB if not taken)
    // a5(x15) = loaded byte value
    assign o_r1 = dbg_regs[3];
    assign o_r2 = dbg_regs[15];
    assign o_r3 = dbg_pc;
    // Pass if branch was taken (x3 = 0xAA)
    assign o_pass = dbg_regs[3] == 64'hAA;
}

#[test(test_load_use_branch)]
module test_load_use_branch {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_load_use_branch_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(10000);
        $display("x3=%h a5=%h pc=%h pass=%b", r1, r2, r3, pass);
        $assert(pass, "LBU->BNEZ: expected branch taken (x3=0xAA), got not taken (x3=0xBB)");
        $display("load_use_branch test passed");
        $finish();
    }
}
