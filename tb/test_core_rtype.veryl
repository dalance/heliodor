// Integration test for R-type instructions through heliodor_top pipeline
module test_core_rtype_harness (
    clk          : input  clock         ,
    rst          : input  reset         ,
    o_pass       : output logic          ,
    o_done       : output logic          ,
) {
    // Processor interface signals
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;

    // Instantiate the processor core
    inst dut: heliodor_top (
        clk                          ,
        rst                          ,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
    );

    // Simple instruction ROM
    // Program:
    //   0x00: ADDI x1, x0, 5     -> x1 = 5
    //   0x04: ADDI x2, x0, 3     -> x2 = 3
    //   0x08: ADD  x3, x1, x2    -> x3 = 8
    //   0x0C: SUB  x4, x1, x2    -> x4 = 2
    //   0x10+: NOP
    always_comb {
        case imem_addr[7:0] {
            8'h00:   imem_rdata = 32'h00500093; // ADDI x1, x0, 5
            8'h04:   imem_rdata = 32'h00300113; // ADDI x2, x0, 3
            8'h08:   imem_rdata = 32'h002081B3; // ADD  x3, x1, x2
            8'h0C:   imem_rdata = 32'h40208233; // SUB  x4, x1, x2
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    // No data memory accesses expected; tie off read data
    assign dmem_rdata = 64'd0;

    // Cycle counter
    var cycle: logic<8>;
    always_ff {
        if_reset {
            cycle = 8'd0;
        } else {
            cycle = cycle + 8'd1;
        }
    }

    // After enough cycles for pipeline drain, check results
    assign o_done = cycle >= 8'd15;
    assign o_pass = dbg_regs[1] == 64'd5
                 && dbg_regs[2] == 64'd3
                 && dbg_regs[3] == 64'd8
                 && dbg_regs[4] == 64'd2;
}

#[test(test_core_rtype)]
module test_core_rtype {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var done: logic;

    inst harness: test_core_rtype_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_done : done ,
    );

    initial {
        rst.assert(clk);
        clk.next(20);
        $assert(pass, "R-type register values mismatch");
        $display("R-type integration test passed");
        $finish();
    }
}
