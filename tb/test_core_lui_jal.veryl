// Integration test for LUI, AUIPC, and JAL instructions
module test_core_lui_jal_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;

    inst dut: heliodor_top (
        clk                          ,
        rst                          ,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
    );

    assign dmem_rdata = 64'd0;

    // Program:
    //   0x00: LUI   x1, 0xDEADB     -> x1 = 0xFFFFFFFF_DEADB000
    //   0x04: AUIPC x2, 0x00001     -> x2 = 0x04 + 0x1000 = 0x1004
    //   0x08: JAL   x3, +8          -> x3 = 0x0C (return addr), jump to 0x10
    //   0x0C: ADDI  x1, x0, 99      -> SKIPPED (JAL shadow)
    //   0x10: NOP                    -> land here
    //   0x14+: NOP
    //
    // Encoding:
    //   LUI x1, 0xDEADB:  imm[31:12]=0xDEADB, rd=1, op=0110111
    //     = 0xDEADB0B7
    //   AUIPC x2, 0x00001: imm[31:12]=0x00001, rd=2, op=0010111
    //     = 0x00001117
    //   JAL x3, +8:  J-type, offset=8
    //     imm[20|10:1|11|19:12] = 0_0000000100_0_00000000, rd=3, op=1101111
    //     = 0x008001EF
    //   ADDI x1, x0, 99: = 0x06300093
    always_comb {
        case imem_addr[7:0] {
            8'h00:   imem_rdata = 32'hDEADB0B7; // LUI   x1, 0xDEADB
            8'h04:   imem_rdata = 32'h00001117; // AUIPC x2, 0x00001
            8'h08:   imem_rdata = 32'h008001EF; // JAL   x3, +8
            8'h0C:   imem_rdata = 32'h06300093; // ADDI  x1, x0, 99 (skipped)
            8'h10:   imem_rdata = 32'h00000013; // NOP (JAL target)
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x1 = 0xFFFFFFFF_DEADB000 (LUI sign-extends upper 20 bits)
    // x2 = 0x1004 (AUIPC: PC=4 + 0x1000)
    // x3 = 0x0C (JAL return address: PC+4 = 0x08+4)
    assign o_pass = dbg_r1 == 64'hFFFFFFFF_DEADB000
                 && dbg_r2 == 64'h0000000000001004
                 && dbg_r3 == 64'h000000000000000C;
}

#[test(test_core_lui_jal)]
module test_core_lui_jal {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_core_lui_jal_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(45);
        $display(r1, r2, r3, pass);
        $assert(pass, "LUI/AUIPC/JAL register values mismatch");
        $display("LUI/AUIPC/JAL integration test passed");
        $finish();
    }
}
