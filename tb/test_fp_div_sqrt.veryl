// Standalone tests for fp_divider and fp_sqrt modules
module test_fp_div_sqrt_harness (
    clk      : input  clock    ,
    rst      : input  reset    ,
    o_pass   : output logic     ,
    o_r1     : output logic<64>,
    o_r2     : output logic<64>,
    o_r3     : output logic<64>,
) {
    var a_reg: logic<64>;
    var b_reg: logic<64>;
    var sq_reg: logic<64>;
    always_ff (clk, rst) {
        if_reset {
            a_reg  = 64'd0;
            b_reg  = 64'd0;
            sq_reg = 64'd0;
        } else {
            a_reg  = 64'h4024000000000000; // 10.0
            b_reg  = 64'h4014000000000000; // 5.0
            sq_reg = 64'h4010000000000000; // 4.0
        }
    }

    // FDIV: 10.0 / 5.0 = 2.0
    var div_result: logic<64>;
    var div_fflags: logic<5>;
    inst u_div: fp_divider (
        i_a      : a_reg,
        i_b      : b_reg,
        i_rm     : 3'b000,
        o_result : div_result,
        o_fflags : div_fflags,
    );

    // FSQRT: sqrt(4.0) = 2.0
    var sqrt_result: logic<64>;
    var sqrt_fflags: logic<5>;
    inst u_sqrt: fp_sqrt (
        i_a      : sq_reg,
        i_rm     : 3'b000,
        o_result : sqrt_result,
        o_fflags : sqrt_fflags,
    );

    assign o_r1 = div_result;
    assign o_r2 = sqrt_result;
    assign o_r3 = 64'd0;
    // DIV: 10/5 = 2.0 = 0x4000000000000000
    // SQRT: sqrt(4.0) = 2.0 = 0x4000000000000000
    assign o_pass = div_result  == 64'h4000000000000000
                 && sqrt_result == 64'h4000000000000000;
}

#[test(test_fp_div_sqrt)]
module test_fp_div_sqrt {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_fp_div_sqrt_harness (
        clk, rst,
        o_pass: pass, o_r1: r1, o_r2: r2, o_r3: r3,
    );

    initial {
        rst.assert(clk);
        clk.next(10);
        $display(r1, r2, r3, pass);
        $assert(pass, "fp_div 10/5 and fp_sqrt(4) should both be 2.0");
        $display("fp_div/sqrt test passed");
        $finish();
    }
}
