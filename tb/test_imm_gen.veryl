// Immediate generator unit test
module test_imm_gen_harness (
    clk   : input  clock,
    rst   : input  reset,
    o_pass: output logic,
) {
    import riscv_pkg::ImmType;

    var instr   : logic  <32>;
    var imm_type: ImmType    ;
    var imm     : logic  <64>;

    inst dut: imm_gen (
        i_instr   : instr   ,
        i_imm_type: imm_type,
        o_imm     : imm     ,
    );

    var tc: logic<8>;
    always_ff {
        if_reset {
            tc = 8'd0;
        } else {
            tc = tc + 8'd1;
        }
    }

    always_comb {
        instr    = 32'd0;
        imm_type = ImmType::I_TYPE;

        case tc {
            // I-type: ADDI x1, x0, 42 -> imm = 42
            // inst[31:20] = 0x02A = 42
            8'd1: {
                instr    = 32'h02A00093;
                imm_type = ImmType::I_TYPE;
            }
            // I-type: negative imm = -1 (0xFFF)
            8'd2: {
                instr    = 32'hFFF00093;
                imm_type = ImmType::I_TYPE;
            }
            // S-type: imm = 8 -> {inst[31:25]=0, inst[11:7]=01000}
            8'd3: {
                instr    = 32'h00112423;
                imm_type = ImmType::S_TYPE;
            }
            // B-type: BEQ with offset 8 -> {0,0000100,0}
            8'd4: {
                instr    = 32'h00000463;
                imm_type = ImmType::B_TYPE;
            }
            // U-type: LUI x1, 0xDEADB -> {DEADB, 00000000000}
            8'd5: {
                instr    = 32'hDEADB0B7;
                imm_type = ImmType::U_TYPE;
            }
            // J-type: JAL x1, 8 -> offset = 8
            8'd6: {
                instr    = 32'h008000EF;
                imm_type = ImmType::J_TYPE;
            }
            default: {}
        }
    }

    // Verify immediate output matches expected values
    var exp: logic<64>;
    always_comb {
        exp = 64'd0;
        case tc {
            8'd1   : exp = 64'd42; // I-type: 42
            8'd2   : exp = 64'hFFFFFFFFFFFFFFFF; // I-type: -1
            8'd3   : exp = 64'd8; // S-type: 8
            8'd4   : exp = 64'd8; // B-type: 8
            8'd5   : exp = 64'hFFFFFFFFDEADB000; // U-type: 0xDEADB000 sign-extended
            8'd6   : exp = 64'd8; // J-type: 8
            default: {}
        }
    }
    assign o_pass = (tc >: 8'd5) && imm == exp;
}

#[test(test_imm_gen)]
module test_imm_gen {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;

    inst harness: test_imm_gen_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
    );

    initial {
        rst.assert(clk);
        clk.next  (7);
        $assert   (pass, "Immediate generator test failed");
        $display  ("Immediate generator test passed");
        $finish   ();
    }
}
