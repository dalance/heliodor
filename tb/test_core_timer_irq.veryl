// Integration test for timer interrupt: CLINT timer → mtvec → handler → MRET
module test_core_timer_irq_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;

    inst dut: heliodor_top (
        clk                          ,
        rst                          ,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
    );

    assign dmem_rdata = 64'd0;

    // Program: Set up timer interrupt, wait for it, handle in trap handler
    //
    // --- Main code ---
    //   0x00: LUI x1, 0x02004       # x1 = 0x02004000 (CLINT mtimecmp)
    //   0x04: NOP
    //   0x08: NOP
    //   0x0C: NOP
    //   0x10: ADDI x2, x0, 500      # x2 = 500 (mtimecmp: accounts for icache fill delay)
    //   0x14: NOP
    //   0x18: NOP
    //   0x1C: NOP
    //   0x20: SD x2, 0(x1)          # Store mtimecmp = 500 to CLINT at 0x02004000
    //   0x24: NOP
    //   0x28: NOP
    //   0x2C: NOP
    //   0x30: ADDI x3, x0, 0x80     # x3 = 0x80 (trap handler address)
    //   0x34: NOP
    //   0x38: NOP
    //   0x3C: NOP
    //   0x40: CSRRW x0, mtvec, x3   # mtvec = 0x80
    //   0x44: NOP
    //   0x48: NOP
    //   0x4C: NOP
    //   0x50: ADDI x4, x0, 0x80     # x4 = 0x80 (mie.MTIE = bit 7)
    //   0x54: NOP
    //   0x58: NOP
    //   0x5C: NOP
    //   0x60: CSRRW x0, mie, x4     # mie = 0x80 (enable timer interrupt)
    //   0x64: NOP
    //   0x68: NOP
    //   0x6C: NOP
    //   0x70: CSRRSI x0, mstatus, 8 # mstatus.MIE = 1 (global interrupt enable)
    //                                # CSRRSI: funct3=110, imm=01000 (x8), csr=mstatus(0x300)
    //   0x74: ADDI x1, x0, 1        # x1 = 1 (before interrupt)
    //   0x78..0x7C: NOP loop waiting for interrupt
    //
    // --- Trap handler at 0x80 ---
    //   0x80: ADDI x2, x0, 2        # x2 = 2 (in handler)
    //   0x84: NOP
    //   0x88: NOP
    //   0x8C: NOP
    //   0x90: LUI x20, 0x02004      # x20 = 0x02004000 (CLINT mtimecmp)
    //   0x94: NOP
    //   0x98: NOP
    //   0x9C: NOP
    //   0xA0: ADDI x21, x0, -1      # x21 = 0xFFFFFFFFFFFFFFFF (disable timer)
    //   0xA4: NOP
    //   0xA8: NOP
    //   0xAC: NOP
    //   0xB0: SD x21, 0(x20)        # mtimecmp = MAX (clear timer interrupt)
    //   0xB4: NOP
    //   0xB8: NOP
    //   0xBC: NOP
    //   0xC0: MRET                   # Return from interrupt

    // Encodings:
    //   LUI x1, 0x02000:         0x02000_0B7  (imm=0x02000, rd=x1)
    //   ADDI x2, x0, 500:       0x1F4_00_113  (imm=500, rs1=x0, rd=x2)
    //   SD x2, 0(x1):           0x002_0B_023  (imm=0, rs2=x2, rs1=x1, funct3=011)
    //   ADDI x3, x0, 0x80:      0x080_00_193
    //   CSRRW x0, mtvec, x3:    0x305_19_073
    //   ADDI x4, x0, 0x80:      0x080_00_213
    //   CSRRW x0, mie, x4:      0x304_21_073
    //   CSRRSI x0, mstatus, 8:  0x300_46_073  (csr=0x300, imm=01000=x8, funct3=110, rd=x0)
    //   ADDI x1, x0, 1:         0x001_00_093
    //   ADDI x2, x0, 2:         0x002_00_113
    //   LUI x20, 0x02004:       0x02004_A37  (rd=x20)
    //   ADDI x21, x0, -1:       0xFFF_00_A93
    //   SD x21, 0(x20):         0x015_A3_023 (rs2=x21, rs1=x20, funct3=011)
    //   MRET:                    0x302_00_073

    always_comb {
        case imem_addr[7:0] {
            // Setup: CLINT mtimecmp, mtvec, mie, mstatus.MIE
            8'h00:   imem_rdata = 32'h020040B7; // LUI x1, 0x02004
            8'h04:   imem_rdata = 32'h00000013; // NOP
            8'h08:   imem_rdata = 32'h00000013; // NOP
            8'h0C:   imem_rdata = 32'h00000013; // NOP
            8'h10:   imem_rdata = 32'h1F400113; // ADDI x2, x0, 500
            8'h14:   imem_rdata = 32'h00000013; // NOP
            8'h18:   imem_rdata = 32'h00000013; // NOP
            8'h1C:   imem_rdata = 32'h00000013; // NOP
            8'h20:   imem_rdata = 32'h0020B023; // SD x2, 0(x1)
            8'h24:   imem_rdata = 32'h00000013; // NOP
            8'h28:   imem_rdata = 32'h00000013; // NOP
            8'h2C:   imem_rdata = 32'h00000013; // NOP
            8'h30:   imem_rdata = 32'h08000193; // ADDI x3, x0, 0x80
            8'h34:   imem_rdata = 32'h00000013; // NOP
            8'h38:   imem_rdata = 32'h00000013; // NOP
            8'h3C:   imem_rdata = 32'h00000013; // NOP
            8'h40:   imem_rdata = 32'h30519073; // CSRRW x0, mtvec, x3
            8'h44:   imem_rdata = 32'h00000013; // NOP
            8'h48:   imem_rdata = 32'h00000013; // NOP
            8'h4C:   imem_rdata = 32'h00000013; // NOP
            8'h50:   imem_rdata = 32'h08000213; // ADDI x4, x0, 0x80
            8'h54:   imem_rdata = 32'h00000013; // NOP
            8'h58:   imem_rdata = 32'h00000013; // NOP
            8'h5C:   imem_rdata = 32'h00000013; // NOP
            8'h60:   imem_rdata = 32'h30421073; // CSRRW x0, mie, x4
            8'h64:   imem_rdata = 32'h00000013; // NOP
            8'h68:   imem_rdata = 32'h00000013; // NOP
            8'h6C:   imem_rdata = 32'h00000013; // NOP
            8'h70:   imem_rdata = 32'h30046073; // CSRRSI x0, mstatus, 8
            8'h74:   imem_rdata = 32'h00100093; // ADDI x1, x0, 1
            8'h78:   imem_rdata = 32'h00000013; // NOP (wait for interrupt)
            8'h7C:   imem_rdata = 32'h00000013; // NOP

            // After MRET returns, x3 = 3
            // The PC after MRET will be mepc (= interrupted PC in the NOP region)
            // We set x3 = 3 at the first instruction after the NOP wait region
            // But since interrupt is async, we don't know exact return PC.
            // Instead, use a simpler approach: after MRET returns somewhere
            // in 0x74-0x7C, it continues executing NOPs until falling through.
            // We don't set x3 here; the test checks x1=1, x2=2.

            // Trap handler at 0x80
            8'h80:   imem_rdata = 32'h00200113; // ADDI x2, x0, 2
            8'h84:   imem_rdata = 32'h00000013; // NOP
            8'h88:   imem_rdata = 32'h00000013; // NOP
            8'h8C:   imem_rdata = 32'h00000013; // NOP
            8'h90:   imem_rdata = 32'h02004A37; // LUI x20, 0x02004
            8'h94:   imem_rdata = 32'h00000013; // NOP
            8'h98:   imem_rdata = 32'h00000013; // NOP
            8'h9C:   imem_rdata = 32'h00000013; // NOP
            8'hA0:   imem_rdata = 32'hFFF00A93; // ADDI x21, x0, -1
            8'hA4:   imem_rdata = 32'h00000013; // NOP
            8'hA8:   imem_rdata = 32'h00000013; // NOP
            8'hAC:   imem_rdata = 32'h00000013; // NOP
            8'hB0:   imem_rdata = 32'h015A3023; // SD x21, 0(x20)
            8'hB4:   imem_rdata = 32'h00000013; // NOP
            8'hB8:   imem_rdata = 32'h00000013; // NOP
            8'hBC:   imem_rdata = 32'h00000013; // NOP
            8'hC0:   imem_rdata = 32'h30200073; // MRET
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x1 = 1 (set before interrupt)
    // x2 = 2 (set in trap handler)
    assign o_pass = dbg_r1 == 64'd1
                 && dbg_r2 == 64'd2;
}

#[test(test_core_timer_irq)]
module test_core_timer_irq {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_core_timer_irq_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(2000);
        $display(r1, r2, r3, pass);
        $assert(pass, "Timer interrupt test failed");
        $display("Timer interrupt test passed");
        $finish();
    }
}
