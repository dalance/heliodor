// Tight CAS loop test: verifies LR/SC without NOP bubbles
// Mimics the kernel's set_pfnblock_flags_mask CAS pattern
module test_cas_loop_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var _dbg_pass : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var _iptw_addr: logic<64>     ;
    var _iptw_req : logic         ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : _iptw_addr,
        o_iptw_req     : _iptw_req ,
        i_iptw_rdata   : 64'd0     ,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : _dbg_pass ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
    );

    // Larger data memory (256 doublewords = 2KB) to exercise dcache
    var mem       : logic<64> [256];
    let word_addr : logic<8>        = dmem_addr[10:3];
    assign dmem_rdata = mem[word_addr];

    always_ff (clk, rst) {
        if_reset {
            for i: i32 in 0..256 {
                mem[i] = 64'd0;
            }
        } else if dmem_wen {
            mem[word_addr] = dmem_wdata;
        }
    }

    // Program: Two consecutive CAS loops on DIFFERENT cache lines
    // First CAS at addr 0x00, second CAS at addr 0x40 (different cache line)
    // This tests dcache write-through across cache lines
    //
    // Encodings verified via riscv64 assembler
    always_comb {
        case imem_addr[7:0] {
            // Setup
            8'h00: imem_rdata = 32'h00000793; // addi a5, x0, 0      # a5 = addr1 = 0
            8'h04: imem_rdata = 32'h00300913; // addi s2, x0, 3      # s2 = flags
            8'h08: imem_rdata = 32'hFFC00413; // addi s0, x0, -4     # s0 = ~mask
            8'h0C: imem_rdata = 32'h04200293; // addi t0, x0, 0x42   # t0 = init
            8'h10: imem_rdata = 32'h0057B023; // sd t0, 0(a5)        # M[0] = 0x42

            // CAS1 at addr 0x00
            8'h14: imem_rdata = 32'h0007B703; // ld a4, 0(a5)
            8'h18: imem_rdata = 32'h00E47633; // and a2, s0, a4
            8'h1C: imem_rdata = 32'h00070693; // mv a3, a4
            8'h20: imem_rdata = 32'h01266633; // or a2, a2, s2
            8'h24: imem_rdata = 32'h1007B72F; // lr.d a4, (a5)
            8'h28: imem_rdata = 32'h00D71863; // bne a4, a3, +16 (→0x38)
            8'h2C: imem_rdata = 32'h18C7B5AF; // sc.d a1, a2, (a5)
            8'h30: imem_rdata = 32'hFE059AE3; // bnez a1, -12 (→0x24)
            8'h34: imem_rdata = 32'h0330000F; // fence rw,rw
            8'h38: imem_rdata = 32'hFCE69EE3; // bne a3, a4, -36 (→0x14)

            // CAS2: SAME address 0x00, different flags (s2=5)
            // Simulates calling set_pfnblock_flags_mask twice on same bitmap word
            8'h3C: imem_rdata = 32'h00500913; // addi s2, x0, 5      # new flags
            8'h40: imem_rdata = 32'h00000793; // addi a5, x0, 0      # same addr

            // CAS2 at addr 0x00 (value was changed by CAS1)
            8'h44: imem_rdata = 32'h0007B703; // ld a4, 0(a5)
            8'h48: imem_rdata = 32'h00E47633; // and a2, s0, a4
            8'h4C: imem_rdata = 32'h00070693; // mv a3, a4
            8'h50: imem_rdata = 32'h01266633; // or a2, a2, s2
            8'h54: imem_rdata = 32'h1007B72F; // lr.d a4, (a5)
            8'h58: imem_rdata = 32'h00D71863; // bne a4, a3, +16 (→0x68)
            8'h5C: imem_rdata = 32'h18C7B5AF; // sc.d a1, a2, (a5)
            8'h60: imem_rdata = 32'hFE059AE3; // bnez a1, -12 (→0x54)
            8'h64: imem_rdata = 32'h0330000F; // fence rw,rw
            8'h68: imem_rdata = 32'hFCE69EE3; // bne a3, a4, -36 (→0x44)

            // Success: both CAS on same addr completed
            8'h6C  : imem_rdata = 32'h0AA00193; // addi x3, x0, 0xAA
            8'h70  : imem_rdata = 32'h0000006F; // jal x0, 0 (halt)
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1   = dbg_regs[13]; // a3 (expected)
    assign o_r2   = dbg_regs[14]; // a4 (loaded)
    assign o_r3   = dbg_r3; // x3 (0xAA = success)
    assign o_pass = dbg_r3 == 64'hAA;
}

#[test(test_cas_loop)]
module test_cas_loop {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_cas_loop_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (500);
        $display  ("a3=%h a4=%h x3=%h pass=%b", r1, r2, r3, pass);
        $assert   (pass, "CAS loop: expected x3=0xAA (CAS succeeded)");
        $display  ("CAS loop test passed");
        $finish   ();
    }
}
