// S-mode timer interrupt test: verifies timer IRQ delegation to S-mode.
// M-mode sets up CLINT timer and delegates STIP to S-mode.
// S-mode enables interrupts and spins; timer fires → S-mode handler.
module test_smode_timer_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var _iptw_addr: logic<64>     ;
    var _iptw_req : logic         ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : _iptw_addr,
        o_iptw_req     : _iptw_req ,
        i_iptw_rdata   : 64'd0     ,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
    );

    // Code memory (read-only, 128 words = 512 bytes)
    var code_mem: logic<32> [128];
    initial {
        $readmemh("test/hex/smode_timer_test.hex", code_mem);
    }

    // CLINT read: dmem reads at 0x02xxxxxx are handled by heliodor's CLINT
    // Regular data memory (small, for stack if needed)
    var data_mem: logic<64> [32];
    always_ff (clk, rst) {
        if_reset {
            for i: i32 in 0..32 {
                data_mem[i] = 64'd0;
            }
        } else if dmem_wen && dmem_addr[31:24] == 8'h00 {
            data_mem[dmem_addr[7:3]] = dmem_wdata;
        }
    }

    // Instruction memory: only from code_mem
    assign imem_rdata = code_mem[imem_addr[8:2]];

    // Data read: regular memory (CLINT/PLIC reads handled internally by heliodor)
    assign dmem_rdata = if dmem_addr[31:24] == 8'h00 ? data_mem[dmem_addr[7:3]] : 64'd0;

    // Debug: dump stall/interrupt state
    var dbg_cycle: logic<32>;
    always_ff (clk, rst) {
        if_reset {
            dbg_cycle = 32'd0;
        } else {
            dbg_cycle = dbg_cycle + 32'd1;
            if dbg_cycle == 32'd1000 {
                $display("c1000: x1=%h x3=%h mcause=%h mip=%h mie=%h mideleg=%h pc=%h", dbg_r1, dbg_r3, dbg_regs[2], dbg_regs[10], dbg_regs[11], dbg_regs[12], dbg_pc);
            }
        }
    }

    assign o_r1   = dbg_r1; // x1 (S-mode running)
    assign o_r2   = dbg_r2; // x2 (sepc from handler)
    assign o_r3   = dbg_r3; // x3 (result: 0xAA=success)
    assign o_pass = dbg_r3 == 64'hAA;
}

#[test(test_smode_timer)]
module test_smode_timer {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_smode_timer_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (50000);
        $display  ("x1=%h x2=%h x3=%h pass=%b", r1, r2, r3, pass);
        $assert   (pass, "S-mode timer: expected x3=0xAA (timer IRQ delegated to S-mode)");
        $display  ("S-mode timer interrupt test passed");
        $finish   ();
    }
}
