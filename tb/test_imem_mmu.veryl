// Instruction fetch MMU test: S-mode code executes from a non-identity-mapped
// virtual address (VA 0x10000 → PA 0x5000), verifying that the imem_mmu
// correctly translates instruction fetches through Sv39 page tables.
module test_imem_mmu_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var iptw_addr : logic<64>     ;
    var iptw_req  : logic         ;
    var iptw_rdata: logic<64>     ;
    var uart_tx   : logic         ;
    var uart_data : logic<8>      ;
    var _dbg_stall: logic<8>      ;
    var _iptw_addr: logic<64>     ;
    var _iptw_req : logic         ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : iptw_addr ,
        o_iptw_req     : iptw_req  ,
        i_iptw_rdata   : iptw_rdata,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
        o_uart_tx      : uart_tx   ,
        o_uart_data    : uart_data ,
        o_dbg_stall    : _dbg_stall,
    );

    // Code memory (read-only, 256 words = 1KB)
    var code_mem: logic<32> [256];
    initial {
        $readmemh("test/hex/imem_mmu_test.hex", code_mem);
    }

    // Data memory (read-write, 4096 words = 16KB, mapped to 0x1000-0x8FFF)
    // 0x1000-0x1FFF: L2 page table
    // 0x2000-0x2FFF: L1 page table
    // 0x3000-0x3FFF: L0 page table
    // 0x4000-0x4FFF: Data page
    // 0x5000-0x5FFF: S-mode code page (copied by M-mode)
    // 0x7000-0x7FFF: Stack
    var data_mem: logic<32> [8192];

    // Instruction read: PA 0x0000-0x0FFF from code_mem, else from data_mem
    let imem_is_data : logic     = imem_addr[15:0] >= 16'h1000;
    let imem_byte_off: logic<16> = imem_addr[15:0] - 16'h1000;
    assign imem_rdata    = if imem_is_data ? data_mem[imem_byte_off[14:2]] : code_mem[imem_addr[9:2]];

    // Instruction PTW read (64-bit)
    let iptw_is_data : logic     = iptw_addr[15:0] >= 16'h1000;
    let iptw_byte_off: logic<16> = iptw_addr[15:0] - 16'h1000;
    let iptw_dw_lo   : logic<13> = {iptw_byte_off[15:3], 1'b0};
    let iptw_dw_hi   : logic<13> = {iptw_byte_off[15:3], 1'b1};

    // Data memory address decode: PA 0x1000-0x8FFF → data_mem[0..8191]
    let is_data: logic = dmem_addr[15:12] != 4'h0 && dmem_addr[15:12] != 4'h9 && dmem_addr[15:12] != 4'hA && dmem_addr[31:16] == 16'd0;
    // Byte offset from 0x1000, then doubleword index
    let dmem_byte_off: logic<16> = dmem_addr[15:0] - 16'h1000;
    let data_dw_lo   : logic<13> = {dmem_byte_off[14:3], 1'b0};
    let data_dw_hi   : logic<13> = {dmem_byte_off[14:3], 1'b1};
    let code_dw_lo   : logic<8>  = {dmem_addr[9:3], 1'b0};
    let code_dw_hi   : logic<8>  = {dmem_addr[9:3], 1'b1};

    // Write-first forwarding: when dmem writes, forward the new value to
    // same-cycle reads (iptw, dmem, imem). Prevents NBA 1-cycle stale read.
    var fwd_lo: logic<32>;
    var fwd_hi: logic<32>;
    always_comb {
        fwd_lo = data_mem[data_dw_lo];
        fwd_hi = data_mem[data_dw_hi];
        if dmem_wen && is_data {
            if dmem_wstrb[0] { fwd_lo[7:0]   = dmem_wdata[7:0];   }
            if dmem_wstrb[1] { fwd_lo[15:8]  = dmem_wdata[15:8];  }
            if dmem_wstrb[2] { fwd_lo[23:16] = dmem_wdata[23:16]; }
            if dmem_wstrb[3] { fwd_lo[31:24] = dmem_wdata[31:24]; }
            if dmem_wstrb[4] { fwd_hi[7:0]   = dmem_wdata[39:32]; }
            if dmem_wstrb[5] { fwd_hi[15:8]  = dmem_wdata[47:40]; }
            if dmem_wstrb[6] { fwd_hi[23:16] = dmem_wdata[55:48]; }
            if dmem_wstrb[7] { fwd_hi[31:24] = dmem_wdata[63:56]; }
        }
    }

    // Instruction PTW memory read with write forwarding
    let iptw_lo: logic<32> = if dmem_wen && is_data && iptw_dw_lo == data_dw_lo ? fwd_lo
                            : if dmem_wen && is_data && iptw_dw_lo == data_dw_hi ? fwd_hi
                            : data_mem[iptw_dw_lo];
    let iptw_hi: logic<32> = if dmem_wen && is_data && iptw_dw_hi == data_dw_lo ? fwd_lo
                            : if dmem_wen && is_data && iptw_dw_hi == data_dw_hi ? fwd_hi
                            : data_mem[iptw_dw_hi];
    assign iptw_rdata = if iptw_is_data ? {iptw_hi, iptw_lo}
        : {code_mem[{iptw_addr[9:3], 1'b1}], code_mem[{iptw_addr[9:3], 1'b0}]};

    // Data read (64-bit, no forwarding — forwarding only for iptw_rdata)
    assign dmem_rdata = if is_data ? {data_mem[data_dw_hi], data_mem[data_dw_lo]} : {code_mem[code_dw_hi], code_mem[code_dw_lo]};

    // Data write
    always_ff (clk, rst) {
        if_reset {} else if dmem_wen {
            if is_data {
                if dmem_wstrb[0] {
                    data_mem[data_dw_lo][7:0] = dmem_wdata[7:0];
                }
                if dmem_wstrb[1] {
                    data_mem[data_dw_lo][15:8] = dmem_wdata[15:8];
                }
                if dmem_wstrb[2] {
                    data_mem[data_dw_lo][23:16] = dmem_wdata[23:16];
                }
                if dmem_wstrb[3] {
                    data_mem[data_dw_lo][31:24] = dmem_wdata[31:24];
                }
                if dmem_wstrb[4] {
                    data_mem[data_dw_hi][7:0] = dmem_wdata[39:32];
                }
                if dmem_wstrb[5] {
                    data_mem[data_dw_hi][15:8] = dmem_wdata[47:40];
                }
                if dmem_wstrb[6] {
                    data_mem[data_dw_hi][23:16] = dmem_wdata[55:48];
                }
                if dmem_wstrb[7] {
                    data_mem[data_dw_hi][31:24] = dmem_wdata[63:56];
                }
            }
        }
    }

    // Debug: dump after cycle 100
    var dbg_cycle: logic<32>;
    always_ff (clk, rst) {
        if_reset {
            dbg_cycle = 32'd0;
        } else {
            dbg_cycle = dbg_cycle + 32'd1;
            if dbg_cycle == 32'd10000 {
                $display("PA5000: dm[4096]=%h [97]=%h [98]=%h [99]=%h [100]=%h", data_mem[4096], data_mem[4097], data_mem[4098], data_mem[4099], data_mem[4100]);
            }
            // Debug trace disabled — re-enable for debugging
            // if dbg_pc[63:12] == 52'h10 { ... }
        }
    }

    assign o_r1   = dbg_regs[3];
    assign o_r2   = dbg_regs[4]; // scause
    assign o_r3   = dbg_pc;
    assign o_pass = dbg_regs[3] == 64'hAA;
}

#[test(test_imem_mmu)]
module test_imem_mmu {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_imem_mmu_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (200000);
        $display  ("x3=%h scause=%h pc=%h pass=%b", r1, r2, r3, pass);
        $assert   (pass, "imem MMU: expected x3=0xAA (non-identity instruction fetch passed)");
        $display  ("Instruction fetch MMU test passed");
        $finish   ();
    }
}
