// Regression: JAL pipeline flush + dcache miss fill.
module test_jal_dcache_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var uart_tx   : logic;
    var uart_data : logic<8>;

    inst dut: heliodor_top (
        clk, rst,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
        o_uart_tx    : uart_tx       ,
        o_uart_data  : uart_data     ,
    );

    var mem: logic<32> [8192];
    initial {
        $readmemh("test/hex/jal_dcache_test.hex", mem);
    }
    assign imem_rdata = mem[imem_addr[14:2]];
    let dword_idx: logic<12> = dmem_addr[14:3];
    assign dmem_rdata = {mem[{dword_idx, 1'b1}], mem[{dword_idx, 1'b0}]};

    // x3 = LD from 0x160 (should be 0xDEADBEEFCAFEBABE)
    // x6 = marker (should be 1)
    assign o_r1 = dbg_regs[3];
    assign o_r2 = dbg_regs[6];
    assign o_r3 = dbg_pc;
    assign o_pass = dbg_regs[3] == 64'hDEADBEEFCAFEBABE && dbg_regs[6] == 64'd1;
}

#[test(test_jal_dcache)]
module test_jal_dcache {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_jal_dcache_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(1000);
        $display(r1, r2, r3, pass);
        $assert(pass, "JAL + dcache fill: LD returned wrong data");
        $display("JAL + dcache fill test passed");
        $finish();
    }
}
