// Integration test for JALR and W-variant instructions
module test_core_jalr_w_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;

    inst dut: heliodor_top (
        clk                          ,
        rst                          ,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
    );

    assign dmem_rdata = 64'd0;

    // Program: test JALR and ADDW/SUBW
    //   0x00: ADDI   x1, x0, 0x14    -> x1 = 0x14 (target address)
    //   0x04: JALR   x2, x1, 0       -> x2 = 0x08 (PC+4), jump to 0x14
    //   0x08: ADDI   x3, x0, 99      -> SKIPPED
    //   0x0C: ADDI   x3, x0, 99      -> SKIPPED
    //   0x10: ADDI   x3, x0, 99      -> SKIPPED
    //   0x14: LUI    x3, 0x80000     -> x3 = 0x00000000_80000000 (2^31)
    //   0x18: ADDIW  x3, x3, 1       -> x3 = sext32(0x80000001) = 0xFFFFFFFF_80000001
    //   0x1C+: NOP
    //
    // Encoding:
    //   ADDI x1, x0, 0x14:  = 0x01400093
    //   JALR x2, x1, 0:     imm=0, rs1=1, f3=000, rd=2, op=1100111
    //     = 0x000080E7
    //   ADDI x3, x0, 99:    = 0x06300193
    //   LUI x3, 0x80000:    = 0x800001B7
    //   ADDIW x3, x3, 1:    imm=1, rs1=3, f3=000, rd=3, op=0011011
    //     = 0x0011819B
    always_comb {
        case imem_addr[7:0] {
            8'h00:   imem_rdata = 32'h01400093; // ADDI  x1, x0, 0x14
            8'h04:   imem_rdata = 32'h00008167; // JALR  x2, x1, 0
            8'h08:   imem_rdata = 32'h06300193; // ADDI  x3, x0, 99 (skipped)
            8'h0C:   imem_rdata = 32'h06300193; // ADDI  x3, x0, 99 (skipped)
            8'h10:   imem_rdata = 32'h06300193; // ADDI  x3, x0, 99 (skipped)
            8'h14:   imem_rdata = 32'h800001B7; // LUI   x3, 0x80000
            8'h18:   imem_rdata = 32'h0011819B; // ADDIW x3, x3, 1
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x1 = 0x14 (target address)
    // x2 = 0x08 (JALR return address: PC+4 = 0x04+4)
    // x3 = 0xFFFFFFFF_80000001 (ADDIW sign-extends 32-bit result)
    assign o_pass = dbg_r1 == 64'h0000000000000014
                 && dbg_r2 == 64'h0000000000000008
                 && dbg_r3 == 64'hFFFFFFFF80000001;
}

#[test(test_core_jalr_w)]
module test_core_jalr_w {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_core_jalr_w_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(45);
        $display(r1, r2, r3, pass);
        $assert(pass, "JALR/W-variant register values mismatch");
        $display("JALR/W-variant integration test passed");
        $finish();
    }
}
