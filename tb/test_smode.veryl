// S-mode test: M→S via MRET, then ECALL from S → delegated S-mode trap handler
module test_smode_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var uart_tx   : logic         ;
    var uart_data : logic<8>      ;
    var _dbg_stall: logic<8>      ;
    var _iptw_addr: logic<64>     ;
    var _iptw_req : logic         ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : _iptw_addr,
        o_iptw_req     : _iptw_req ,
        i_iptw_rdata   : 64'd0     ,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
        o_uart_tx      : uart_tx   ,
        o_uart_data    : uart_data ,
    );

    var mem: logic<64> [32];
    always_ff (clk, rst) {
        if_reset {
            for i: i32 in 0..32 {
                mem[i]              = 64'd0;
            }
        } else if dmem_wen {
            mem[dmem_addr[7:3]] = dmem_wdata;
        }
    }
    assign dmem_rdata = mem[dmem_addr[7:3]];

    // Layout:
    //   0x000-0x07F: M-mode init
    //   0x080-0x0BF: S-mode code (mepc=0x80)
    //   0x0C0-0x0FF: S-mode trap handler (stvec=0xC0)
    //   0x100-0x13F: M-mode trap handler (mtvec=0x100)
    always_comb {
        case imem_addr[8:0] {
            // === M-mode init ===
            // 1. medeleg |= (1<<9) — delegate ECALL-from-S
            9'h000: imem_rdata = 32'h00100293; // ADDI x5, x0, 1
            9'h004: imem_rdata = 32'h00000013;
            9'h008: imem_rdata = 32'h00929293; // SLLI x5, x5, 9
            9'h00C: imem_rdata = 32'h00000013;
            9'h010: imem_rdata = 32'h3022A073; // CSRRS x0, medeleg, x5
            9'h014: imem_rdata = 32'h00000013;

            // 2. stvec = 0xC0
            9'h018: imem_rdata = 32'h0C000313; // ADDI x6, x0, 0xC0
            9'h01C: imem_rdata = 32'h00000013;
            9'h020: imem_rdata = 32'h10531073; // CSRRW x0, stvec, x6
            9'h024: imem_rdata = 32'h00000013;

            // 3. mtvec = 0x100 (M-mode trap handler, for debugging)
            9'h028: imem_rdata = 32'h10000393; // ADDI x7, x0, 0x100
            9'h02C: imem_rdata = 32'h00000013;
            9'h030: imem_rdata = 32'h30539073; // CSRRW x0, mtvec, x7
            9'h034: imem_rdata = 32'h00000013;

            // 4. mepc = 0x80 (S-mode entry)
            9'h038: imem_rdata = 32'h08000E13; // ADDI x28, x0, 0x80
            9'h03C: imem_rdata = 32'h00000013;
            9'h040: imem_rdata = 32'h341E1073; // CSRRW x0, mepc, x28
            9'h044: imem_rdata = 32'h00000013;

            // 5. mstatus.MPP = 01 (S-mode)
            9'h048: imem_rdata = 32'h00002437; // LUI x8, 0x2 (=0x2000)
            9'h04C: imem_rdata = 32'h00000013;
            9'h050: imem_rdata = 32'h80040413; // ADDI x8, x8, -0x800 (=0x1800)
            9'h054: imem_rdata = 32'h00000013;
            9'h058: imem_rdata = 32'h30043073; // CSRRC x0, mstatus, x8
            9'h05C: imem_rdata = 32'h00000013;
            9'h060: imem_rdata = 32'h00001537; // LUI x10, 1 (=0x1000)
            9'h064: imem_rdata = 32'h00000013;
            9'h068: imem_rdata = 32'h80050513; // ADDI x10, x10, -0x800 (=0x800)
            9'h06C: imem_rdata = 32'h00000013;
            9'h070: imem_rdata = 32'h30052073; // CSRRS x0, mstatus, x10
            9'h074: imem_rdata = 32'h00000013;

            // 6. MRET
            9'h078: imem_rdata = 32'h30200073; // MRET
            9'h07C: imem_rdata = 32'h00000013;

            // === S-mode code (0x80) ===
            9'h080: imem_rdata = 32'h00100093; // ADDI x1, x0, 1 (S-mode marker)
            9'h084: imem_rdata = 32'h00000013;
            9'h088: imem_rdata = 32'h00000013;
            9'h08C: imem_rdata = 32'h00000013;
            9'h090: imem_rdata = 32'h00000013;
            9'h094: imem_rdata = 32'h00000013;
            9'h098: imem_rdata = 32'h00000013;
            9'h09C: imem_rdata = 32'h00000013;
            9'h0A0: imem_rdata = 32'h00000073; // ECALL from S-mode
            9'h0A4: imem_rdata = 32'h00000013;

            // === S-mode trap handler (0xC0) ===
            9'h0C0: imem_rdata = 32'h00200113; // ADDI x2, x0, 2 (handler marker)
            9'h0C4: imem_rdata = 32'h00000013;
            9'h0C8: imem_rdata = 32'h00000013;
            9'h0CC: imem_rdata = 32'h00000013;
            9'h0D0: imem_rdata = 32'h142021F3; // CSRRS x3, scause, x0
            9'h0D4: imem_rdata = 32'h00000013;
            9'h0D8: imem_rdata = 32'h0000006F; // loop

            // === M-mode trap handler (0x100) ===
            9'h100: imem_rdata = 32'h00300113; // ADDI x2, x0, 3 (M-mode handler marker)
            9'h104: imem_rdata = 32'h00000013;
            9'h108: imem_rdata = 32'h00000013;
            9'h10C: imem_rdata = 32'h00000013;
            9'h110: imem_rdata = 32'h34202673; // CSRRS x12, mcause, x0
            9'h114: imem_rdata = 32'h00000013;
            9'h118: imem_rdata = 32'h0000006F; // loop

            default: imem_rdata = 32'h00000013;
        }
    }

    assign o_r1   = dbg_r1; // x1
    assign o_r2   = dbg_r2; // x2
    assign o_r3   = dbg_r3; // x3 = scause (from S-mode handler)
    assign o_pass = dbg_r1 == 64'd1 && dbg_r2 == 64'd2;
}

#[test(test_smode)]
module test_smode {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_smode_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (500);
        $display  (r1, r2, r3, pass);
        $assert   (pass, "S-mode delegation test failed");
        $display  ("S-mode delegation test passed");
        $finish   ();
    }
}
