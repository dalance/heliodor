// S-mode UART test: S-mode code writes to UART through Sv39 MMU.
// Verifies earlycon-style console output from supervisor mode.
module test_smode_uart_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var iptw_addr : logic<64>     ;
    var iptw_req  : logic         ;
    var iptw_rdata: logic<64>     ;
    var uart_tx   : logic         ;
    var uart_data : logic<8>      ;
    var _dbg_stall: logic<8>      ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : iptw_addr ,
        o_iptw_req     : iptw_req  ,
        i_iptw_rdata   : iptw_rdata,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
        o_uart_tx      : uart_tx   ,
        o_uart_data    : uart_data ,
        o_dbg_stall    : _dbg_stall,
    );

    // Code memory (read-only, 128 words = 512 bytes)
    var code_mem: logic<32> [128];
    initial {
        $readmemh("test/hex/smode_uart_test.hex", code_mem);
    }

    // Data memory (8K words = 32KB, PA 0x1000-0x8FFF)
    var data_mem: logic<32> [8192];

    // Instruction read
    let imem_is_data : logic     = imem_addr[15:0] >= 16'h1000;
    let imem_byte_off: logic<16> = imem_addr[15:0] - 16'h1000;
    assign imem_rdata    = if imem_is_data ? data_mem[imem_byte_off[14:2]] : code_mem[imem_addr[8:2]];

    // IPTW read (64-bit)
    let iptw_is_data : logic     = iptw_addr[15:0] >= 16'h1000;
    let iptw_byte_off: logic<16> = iptw_addr[15:0] - 16'h1000;
    // Data memory address decode
    let is_data      : logic     = dmem_addr[31:16] == 16'd0 && dmem_addr[15:12] != 4'h0;
    let dmem_byte_off: logic<16> = dmem_addr[15:0] - 16'h1000;
    let data_dw_lo   : logic<13> = {dmem_byte_off[14:3], 1'b0};
    let data_dw_hi   : logic<13> = {dmem_byte_off[14:3], 1'b1};

    // Write-first forwarding: when dmem writes, forward the new value to
    // same-cycle reads (iptw, dmem, imem). Prevents NBA 1-cycle stale read.
    var fwd_lo: logic<32>;
    var fwd_hi: logic<32>;
    always_comb {
        fwd_lo = data_mem[data_dw_lo];
        fwd_hi = data_mem[data_dw_hi];
        if dmem_wen && is_data {
            if dmem_wstrb[0] {
                fwd_lo[7:0] = dmem_wdata[7:0];
            }
            if dmem_wstrb[1] {
                fwd_lo[15:8] = dmem_wdata[15:8];
            }
            if dmem_wstrb[2] {
                fwd_lo[23:16] = dmem_wdata[23:16];
            }
            if dmem_wstrb[3] {
                fwd_lo[31:24] = dmem_wdata[31:24];
            }
            if dmem_wstrb[4] {
                fwd_hi[7:0] = dmem_wdata[39:32];
            }
            if dmem_wstrb[5] {
                fwd_hi[15:8] = dmem_wdata[47:40];
            }
            if dmem_wstrb[6] {
                fwd_hi[23:16] = dmem_wdata[55:48];
            }
            if dmem_wstrb[7] {
                fwd_hi[31:24] = dmem_wdata[63:56];
            }
        }
    }

    // Instruction PTW memory read with write forwarding
    let iptw_lo_idx: logic<13> = {iptw_byte_off[14:3], 1'b0};
    let iptw_hi_idx: logic<13> = {iptw_byte_off[14:3], 1'b1};
    let iptw_lo    : logic<32> = if dmem_wen && is_data && iptw_lo_idx == data_dw_lo ?
        fwd_lo
    : if dmem_wen && is_data && iptw_lo_idx == data_dw_hi ?
        fwd_hi
    :
        data_mem[iptw_lo_idx]
    ;
    let iptw_hi: logic<32> = if dmem_wen && is_data && iptw_hi_idx == data_dw_lo ?
        fwd_lo
    : if dmem_wen && is_data && iptw_hi_idx == data_dw_hi ?
        fwd_hi
    :
        data_mem[iptw_hi_idx]
    ;
    assign iptw_rdata = if iptw_is_data ? {iptw_hi, iptw_lo} : {code_mem[{iptw_addr[8:3], 1'b1}], code_mem[{iptw_addr[8:3], 1'b0}]};

    // Data memory read (no forwarding — forwarding only for iptw_rdata)
    assign dmem_rdata = if is_data ?
        {data_mem[data_dw_hi], data_mem[data_dw_lo]}
    :
        {code_mem[{dmem_addr[8:3], 1'b1}], code_mem[{dmem_addr[8:3], 1'b0}]}
    ;

    // Data write (byte-strobed)
    always_ff (clk, rst) {
        if_reset {} else if dmem_wen && is_data {
            if dmem_wstrb[0] {
                data_mem[data_dw_lo][7:0] = dmem_wdata[7:0];
            }
            if dmem_wstrb[1] {
                data_mem[data_dw_lo][15:8] = dmem_wdata[15:8];
            }
            if dmem_wstrb[2] {
                data_mem[data_dw_lo][23:16] = dmem_wdata[23:16];
            }
            if dmem_wstrb[3] {
                data_mem[data_dw_lo][31:24] = dmem_wdata[31:24];
            }
            if dmem_wstrb[4] {
                data_mem[data_dw_hi][7:0] = dmem_wdata[39:32];
            }
            if dmem_wstrb[5] {
                data_mem[data_dw_hi][15:8] = dmem_wdata[47:40];
            }
            if dmem_wstrb[6] {
                data_mem[data_dw_hi][23:16] = dmem_wdata[55:48];
            }
            if dmem_wstrb[7] {
                data_mem[data_dw_hi][31:24] = dmem_wdata[63:56];
            }
        }
    }

    // Capture UART output
    var uart_buf: logic<8> [8];
    var uart_cnt: logic<4>    ;
    always_ff (clk, rst) {
        if_reset {
            uart_cnt = 4'd0;
        } else if uart_tx && uart_cnt <: 4'd8 {
            uart_buf[uart_cnt] = uart_data;
            uart_cnt           = uart_cnt + 4'd1;
        }
    }

    assign o_r1 = dbg_r1; // x1
    assign o_r2 = dbg_r2; // x2 (rdtime result)
    assign o_r3 = dbg_r3; // x3 (0xAA = success)
    // Pass: x3=0xAA and UART printed at least 2 chars ('H', 'i')
    assign o_pass = dbg_r3 == 64'hAA && uart_cnt >= 4'd2;
}

#[test(test_smode_uart)]
module test_smode_uart {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_smode_uart_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (200000);
        $display  ("x1=%h x2=%h x3=%h pass=%b", r1, r2, r3, pass);
        $assert   (pass, "S-mode UART: expected x3=0xAA and UART output");
        $display  ("S-mode UART test passed");
        $finish   ();
    }
}
