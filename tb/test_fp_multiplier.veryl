// Standalone test for fp_multiplier module
// Tests: 3.0 * 4.0 = 12.0
module test_fp_multiplier_harness (
    clk      : input  clock    ,
    rst      : input  reset    ,
    o_result : output logic<64>,
    o_fflags : output logic<5> ,
    o_pass   : output logic     ,
) {
    var a_reg: logic<64>;
    var b_reg: logic<64>;
    always_ff (clk, rst) {
        if_reset {
            a_reg = 64'd0;
            b_reg = 64'd0;
        } else {
            a_reg = 64'h4008000000000000; // 3.0
            b_reg = 64'h4010000000000000; // 4.0
        }
    }

    var mul_result: logic<64>;
    var mul_fflags: logic<5>;

    inst u_mul: fp_multiplier (
        i_a      : a_reg,
        i_b      : b_reg,
        i_rm     : 3'b000,
        o_result : mul_result,
        o_fflags : mul_fflags,
    );

    assign o_result = mul_result;
    assign o_fflags = mul_fflags;
    assign o_pass   = mul_result == 64'h4028000000000000; // 12.0
}

#[test(test_fp_multiplier)]
module test_fp_multiplier {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var result: logic<64>;
    var fflags: logic<5>;
    var pass  : logic;

    inst harness: test_fp_multiplier_harness (
        clk, rst,
        o_result : result,
        o_fflags : fflags,
        o_pass   : pass,
    );

    initial {
        rst.assert(clk);
        clk.next(10);
        $display(result, fflags, pass);
        $assert(pass, "fp_multiplier 3.0*4.0 should be 12.0");
        $finish();
    }
}
