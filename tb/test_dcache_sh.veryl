// Test: dcache SB/SH write-through and read-back
// Verifies that SH (store halfword) writes correct byte order through dcache.
// Checks for the 2-byte swap bug observed in Linux boot garbled printk.
module test_dcache_sh_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var uart_tx   : logic         ;
    var uart_data : logic<8>      ;
    var _dbg_stall: logic<8>      ;
    var iptw_addr : logic<64>     ;
    var iptw_req  : logic         ;
    var iptw_rdata: logic<64>     ;

    inst dut: heliodor_top #(
        RESET_PC: 0,
    ) (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : iptw_addr ,
        o_iptw_req     : iptw_req  ,
        i_iptw_rdata   : iptw_rdata,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
        o_dbg_stall    : _dbg_stall,
        o_uart_tx      : uart_tx   ,
        o_uart_data    : uart_data ,
    );

    // Program ROM: 512 words
    var rom: logic<32> [512];
    // Data RAM: 8192 words (32KB)
    var ram: logic<32> [8192];

    initial {
        $readmemh("test/hex/dcache_sh_test.hex", rom);
    }

    // Address decode
    let imem_in_rom: logic     = imem_addr[31:12] == 20'd0;
    let rom_idx    : logic<9>  = imem_addr[10:2];
    let ram_lo     : logic<13> = {dmem_addr[14:3], 1'b0};
    let ram_hi     : logic<13> = {dmem_addr[14:3], 1'b1};
    let iptw_lo    : logic<13> = {iptw_addr[14:3], 1'b0};
    let iptw_hi    : logic<13> = {iptw_addr[14:3], 1'b1};

    assign imem_rdata = if imem_in_rom ? rom[rom_idx] : 32'd0;
    assign iptw_rdata = {ram[iptw_hi], ram[iptw_lo]};
    assign dmem_rdata = {ram[ram_hi], ram[ram_lo]};

    // RAM write
    always_ff (clk, rst) {
        if_reset {} else if dmem_wen {
            if dmem_wstrb[0] {
                ram[ram_lo][7:0] = dmem_wdata[7:0];
            }
            if dmem_wstrb[1] {
                ram[ram_lo][15:8] = dmem_wdata[15:8];
            }
            if dmem_wstrb[2] {
                ram[ram_lo][23:16] = dmem_wdata[23:16];
            }
            if dmem_wstrb[3] {
                ram[ram_lo][31:24] = dmem_wdata[31:24];
            }
            if dmem_wstrb[4] {
                ram[ram_hi][7:0] = dmem_wdata[39:32];
            }
            if dmem_wstrb[5] {
                ram[ram_hi][15:8] = dmem_wdata[47:40];
            }
            if dmem_wstrb[6] {
                ram[ram_hi][23:16] = dmem_wdata[55:48];
            }
            if dmem_wstrb[7] {
                ram[ram_hi][31:24] = dmem_wdata[63:56];
            }
        }
    }

    assign o_r1   = dbg_regs[9];  // x9 (actual value on fail)
    assign o_r2   = dbg_regs[11]; // x11 (expected value on fail)
    assign o_r3   = dbg_r3;
    assign o_pass = dbg_r3 == 64'hAA;
}

#[test(test_dcache_sh)]
module test_dcache_sh {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_dcache_sh_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (5000);
        $display  ("x9=%h x11=%h x3=%h pass=%b", r1, r2, r3, pass);
        $assert   (pass, "dcache SB/SH byte order test failed");
        $display  ("dcache SB/SH byte order test passed");
        $finish   ();
    }
}
