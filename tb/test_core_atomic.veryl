// Integration test for A extension: LR/SC and AMOADD
module test_core_atomic_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var _iptw_addr: logic<64>     ;
    var _iptw_req : logic         ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : _iptw_addr,
        o_iptw_req     : _iptw_req ,
        i_iptw_rdata   : 64'd0     ,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
    );

    // Simple data memory (8 doublewords)
    var mem: logic<64> [8];

    // Memory read (combinational)
    let word_addr : logic<3> = dmem_addr[5:3];
    assign dmem_rdata = mem[word_addr];

    // Memory write
    always_ff (clk, rst) {
        if_reset {
            mem[0] = 64'd0;
            mem[1] = 64'd0;
            mem[2] = 64'd0;
            mem[3] = 64'd0;
            mem[4] = 64'd0;
            mem[5] = 64'd0;
            mem[6] = 64'd0;
            mem[7] = 64'd0;
        } else if dmem_wen {
            mem[word_addr] = dmem_wdata;
        }
    }

    // Program: Test LR/SC and AMOADD using address 0x80 (within 512-byte range)
    //
    //   0x00: ADDI x10, x0, 0x80     # x10 = 0x80 (test address, word_addr=16)
    //   0x04-0x0C: NOP
    //   0x10: ADDI x11, x0, 42       # x11 = 42
    //   0x14-0x1C: NOP
    //   0x20: SD x11, 0(x10)         # M[0x80] = 42
    //   0x24-0x2C: NOP
    //   0x30: LR.D x1, (x10)         # x1 = M[0x80] = 42, set reservation
    //   0x34-0x3C: NOP
    //   0x40: ADDI x12, x0, 100      # x12 = 100
    //   0x44-0x4C: NOP
    //   0x50: SC.D x2, x12, (x10)    # M[0x80] = 100, x2 = 0 (success)
    //   0x54-0x5C: NOP
    //   0x60: ADDI x13, x0, 10       # x13 = 10
    //   0x64-0x6C: NOP
    //   0x70: AMOADD.D x3, x13, (x10) # x3 = old M[0x80] = 100, M[0x80] = 110
    //
    // Encodings:
    //   ADDI x10, x0, 0x80:     0x08000513
    //   LR.D x1, (x10):         0x100520AF
    //   SC.D x2, x12, (x10):    0x18C5312F
    //   AMOADD.D x3, x13, (x10): 0x00D531AF

    always_comb {
        case imem_addr[7:0] {
            8'h00  : imem_rdata = 32'h00000513; // ADDI x10, x0, 0 (test addr=0)
            8'h04  : imem_rdata = 32'h00000013; // NOP
            8'h08  : imem_rdata = 32'h00000013; // NOP
            8'h0C  : imem_rdata = 32'h00000013; // NOP
            8'h10  : imem_rdata = 32'h02A00593; // ADDI x11, x0, 42
            8'h14  : imem_rdata = 32'h00000013; // NOP
            8'h18  : imem_rdata = 32'h00000013; // NOP
            8'h1C  : imem_rdata = 32'h00000013; // NOP
            8'h20  : imem_rdata = 32'h00B53023; // SD x11, 0(x10)
            8'h24  : imem_rdata = 32'h00000013; // NOP
            8'h28  : imem_rdata = 32'h00000013; // NOP
            8'h2C  : imem_rdata = 32'h00000013; // NOP
            8'h30  : imem_rdata = 32'h100520AF; // LR.D x1, (x10)
            8'h34  : imem_rdata = 32'h00000013; // NOP
            8'h38  : imem_rdata = 32'h00000013; // NOP
            8'h3C  : imem_rdata = 32'h00000013; // NOP
            8'h40  : imem_rdata = 32'h06400613; // ADDI x12, x0, 100
            8'h44  : imem_rdata = 32'h00000013; // NOP
            8'h48  : imem_rdata = 32'h00000013; // NOP
            8'h4C  : imem_rdata = 32'h00000013; // NOP
            8'h50  : imem_rdata = 32'h18C5312F; // SC.D x2, x12, (x10)
            8'h54  : imem_rdata = 32'h00000013; // NOP
            8'h58  : imem_rdata = 32'h00000013; // NOP
            8'h5C  : imem_rdata = 32'h00000013; // NOP
            8'h60  : imem_rdata = 32'h00A00693; // ADDI x13, x0, 10
            8'h64  : imem_rdata = 32'h00000013; // NOP
            8'h68  : imem_rdata = 32'h00000013; // NOP
            8'h6C  : imem_rdata = 32'h00000013; // NOP
            8'h70  : imem_rdata = 32'h00D531AF; // AMOADD.D x3, x13, (x10)
            8'h74  : imem_rdata = 32'h00000013; // NOP
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x1 = 42 (LR loaded old value)
    // x2 = 0  (SC success) -- check separately
    // x3 = old M[addr] from AMOADD
    // Debug: show all relevant registers
    // x1 = 42 (LR), x2 = 0 (SC success), x3 = AMOADD old value
    assign o_pass = dbg_r1 == 64'd42 && dbg_r2 == 64'd0 && dbg_r3 == 64'd100;
}

#[test(test_core_atomic)]
module test_core_atomic {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_core_atomic_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (500);
        $display  (r1, r2, r3, pass);
        $assert   (pass, "Atomic test failed");
        $display  ("Atomic (LR/SC/AMOADD) test passed");
        $finish   ();
    }
}
