// Integration test for compressed jump/branch instructions:
// C.J (unconditional jump), C.BEQZ, C.BNEZ, C.JALR (link address = PC+2)
module test_core_c_jalr_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var _iptw_addr: logic<64>;
    var _iptw_req : logic;

    inst dut: heliodor_top (
        clk                          ,
        rst                          ,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_iptw_addr  : _iptw_addr    ,
        o_iptw_req   : _iptw_req     ,
        i_iptw_rdata : 64'd0         ,
        i_uart_rx_data : 8'd0        ,
        i_uart_rx_valid: 1'b0        ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
    );

    assign dmem_rdata = 64'd0;

    // Test: C.JALR link address verification
    //
    // Program layout (all at word-aligned addresses for simplicity):
    //
    //   0x00: ADDI x10, x0, 0x40      # x10 = 0x40 (target address for C.JALR)
    //   0x04-0x0C: NOP
    //   0x10: {C.NOP, C.JALR x10}     # PC=0x10: C.JALR x10 → jump to 0x40, x1 = PC+2 = 0x12
    //         C.JALR rd=x10: opcode=10, funct4=1001, rs1=x10, rs2=0
    //         Encoding: 1001_01010_00000_10 = 0x9502
    //         Upper half: C.NOP = 0x0001
    //   0x14-0x1C: NOP (should be skipped)
    //
    //   --- Target at 0x40 ---
    //   0x40: ADDI x2, x1, 0          # x2 = x1 (= return address from C.JALR)
    //   0x44-0x4C: NOP
    //   0x50: ADDI x3, x0, 42         # x3 = 42 (marker: reached target)
    //
    // Expected: x1 = 0x12 (link address = PC+2 of C.JALR at 0x10)
    //           x2 = 0x12 (copy of x1)
    //           x3 = 42 (reached target)
    //
    // Encodings:
    //   ADDI x10, x0, 0x40:     0x04000513  (imm=64, rs1=0, rd=10)
    //   C.JALR x10:             0x9502      (funct4=1001, rs1=01010, rs2=00000, op=10)
    //   ADDI x2, x1, 0:         0x00008113
    //   ADDI x3, x0, 42:        0x02A00193

    always_comb {
        case imem_addr[7:0] {
            8'h00: imem_rdata = 32'h04000513; // ADDI x10, x0, 64 (0x40)
            8'h04: imem_rdata = 32'h00000013; // NOP
            8'h08: imem_rdata = 32'h00000013; // NOP
            8'h0C: imem_rdata = 32'h00000013; // NOP
            // C.JALR x10 at lower half (PC=0x10), C.NOP at upper half
            8'h10: imem_rdata = {16'h0001, 16'h9502}; // {C.NOP, C.JALR x10}
            8'h14: imem_rdata = 32'h00000013; // NOP (should be skipped)
            8'h18: imem_rdata = 32'h00000013;
            8'h1C: imem_rdata = 32'h00000013;

            // Target at 0x40
            8'h40: imem_rdata = 32'h00008113; // ADDI x2, x1, 0  (x2 = x1 = link)
            8'h44: imem_rdata = 32'h00000013; // NOP
            8'h48: imem_rdata = 32'h00000013;
            8'h4C: imem_rdata = 32'h00000013;
            8'h50: imem_rdata = 32'h02A00193; // ADDI x3, x0, 42
            // Infinite loop to prevent PC from wrapping into ROM again
            8'h54: imem_rdata = 32'h0000006F; // JAL x0, 0 (loop forever)

            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x1 = 0x12 (PC+2 of C.JALR at 0x10)
    // x2 = 0x12 (copy of x1)
    // x3 = 42 (reached target)
    assign o_pass = dbg_r1 == 64'h12
                 && dbg_r2 == 64'h12
                 && dbg_r3 == 64'd42;
}

#[test(test_core_c_jalr)]
module test_core_c_jalr {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_core_c_jalr_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(200);
        $display(r1, r2, r3, pass);
        $assert(pass, "C.JALR link address test failed");
        $display("C.JALR link address test passed");
        $finish();
    }
}
