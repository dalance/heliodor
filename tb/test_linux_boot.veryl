// Real Linux kernel boot integration test.
// Boots Linux v5.15 with M-mode SBI firmware through S-mode kernel init.
// Uses the real kernel image (linux_dram_real.hex, ~11 MB) + DTB.
//
// This test is marked #[ignore] because it takes several minutes.
// Run explicitly with: veryl test --ignored --test test_linux_boot
//
// Memory map:
//   PA 0x00000000 : Firmware ROM (16 KB)
//   PA 0x02000000 : CLINT (internal to heliodor_top)
//   PA 0x0C000000 : PLIC  (internal to heliodor_top)
//   PA 0x10000000 : UART  (internal to heliodor_top)
//   PA 0x80000000 : DRAM  (32 MB, kernel Image + DTB)
module test_linux_boot_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var _dbg_pass : logic         ;
    var _dbg_r1   : logic<64>     ;
    var _dbg_r2   : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var iptw_addr : logic<64>     ;
    var iptw_req  : logic         ;
    var iptw_rdata: logic<64>     ;
    var dbg_stall : logic<8>      ;
    var uart_tx   : logic         ;
    var uart_data : logic<8>      ;

    inst dut: heliodor_top #(
        RESET_PC: 0,
    ) (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : iptw_addr ,
        o_iptw_req     : iptw_req  ,
        i_iptw_rdata   : iptw_rdata,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : _dbg_pass ,
        o_dbg_r1       : _dbg_r1   ,
        o_dbg_r2       : _dbg_r2   ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
        o_dbg_stall    : dbg_stall ,
        o_uart_tx      : uart_tx   ,
        o_uart_data    : uart_data ,
    );

    // ============================================================
    // Memory arrays
    // ============================================================
    // Firmware ROM: 16 KB = 4096 × 32-bit words
    var fw_rom: logic<32> [4096];

    // DRAM: 32 MB = 8388608 × 32-bit words (PA 0x80000000 - 0x81FFFFFF)
    var dram: logic<32> [8388608];

    initial {
        $readmemh("test/hex/linux_boot_fw.hex", fw_rom);
        $readmemh("test/hex/linux_dram_real.hex", dram);
    }

    // ============================================================
    // Address decode
    // ============================================================
    // Firmware ROM: PA[31:14] == 0 (0x00000000 - 0x00003FFF)
    let imem_in_fw  : logic = imem_addr[31:14] == 18'd0;
    let dmem_in_dram: logic = dmem_addr[31];
    let iptw_in_fw  : logic = iptw_addr[31:14] == 18'd0;
    let iptw_in_dram: logic = iptw_addr[31];

    // DRAM word index (from PA, 32 MB range → 23-bit index)
    let dram_imem_idx: logic<23> = imem_addr[24:2];
    let dram_dmem_lo : logic<23> = {dmem_addr[24:3], 1'b0};
    let dram_dmem_hi : logic<23> = {dmem_addr[24:3], 1'b1};
    let dram_iptw_lo : logic<23> = {iptw_addr[24:3], 1'b0};
    let dram_iptw_hi : logic<23> = {iptw_addr[24:3], 1'b1};

    // Firmware ROM indices
    let fw_imem_idx: logic<12> = imem_addr[13:2];
    let fw_iptw_lo : logic<12> = {iptw_addr[13:3], 1'b0};
    let fw_iptw_hi : logic<12> = {iptw_addr[13:3], 1'b1};

    // ============================================================
    // Write-first forwarding for DRAM
    // ============================================================
    var fwd_lo: logic<32>;
    var fwd_hi: logic<32>;
    always_comb {
        fwd_lo = dram[dram_dmem_lo];
        fwd_hi = dram[dram_dmem_hi];
        if dmem_wen && dmem_in_dram {
            if dmem_wstrb[0] {
                fwd_lo[7:0] = dmem_wdata[7:0];
            }
            if dmem_wstrb[1] {
                fwd_lo[15:8] = dmem_wdata[15:8];
            }
            if dmem_wstrb[2] {
                fwd_lo[23:16] = dmem_wdata[23:16];
            }
            if dmem_wstrb[3] {
                fwd_lo[31:24] = dmem_wdata[31:24];
            }
            if dmem_wstrb[4] {
                fwd_hi[7:0] = dmem_wdata[39:32];
            }
            if dmem_wstrb[5] {
                fwd_hi[15:8] = dmem_wdata[47:40];
            }
            if dmem_wstrb[6] {
                fwd_hi[23:16] = dmem_wdata[55:48];
            }
            if dmem_wstrb[7] {
                fwd_hi[31:24] = dmem_wdata[63:56];
            }
        }
    }

    // ============================================================
    // Instruction memory read (32-bit)
    // ============================================================
    assign imem_rdata = if imem_in_fw ? fw_rom[fw_imem_idx] : if imem_addr[31] ? dram[dram_imem_idx] : 32'd0;

    // ============================================================
    // Instruction PTW read (64-bit) with write forwarding
    // ============================================================
    let iptw_lo: logic<32> = if iptw_in_dram && dmem_wen && dmem_in_dram && dram_iptw_lo == dram_dmem_lo ?
        fwd_lo
    : if iptw_in_dram && dmem_wen && dmem_in_dram && dram_iptw_lo == dram_dmem_hi ?
        fwd_hi
    : if iptw_in_dram ?
        dram[dram_iptw_lo]
    : if iptw_in_fw ?
        fw_rom[fw_iptw_lo]
    :
        32'd0
    ;
    let iptw_hi: logic<32> = if iptw_in_dram && dmem_wen && dmem_in_dram && dram_iptw_hi == dram_dmem_lo ?
        fwd_lo
    : if iptw_in_dram && dmem_wen && dmem_in_dram && dram_iptw_hi == dram_dmem_hi ?
        fwd_hi
    : if iptw_in_dram ?
        dram[dram_iptw_hi]
    : if iptw_in_fw ?
        fw_rom[fw_iptw_hi]
    :
        32'd0
    ;
    assign iptw_rdata = {iptw_hi, iptw_lo};

    // ============================================================
    // Data memory read (64-bit, no write forwarding for dmem self-read)
    // ============================================================
    assign dmem_rdata = if dmem_in_dram ?
        {dram[dram_dmem_hi], dram[dram_dmem_lo]}
    : if dmem_addr[31:14] == 18'd0 ?
        {fw_rom[{dmem_addr[13:3], 1'b1}], fw_rom[{dmem_addr[13:3], 1'b0}]}
    :
        64'd0
    ;

    // ============================================================
    // Data memory write (byte-strobe, DRAM only)
    // ============================================================
    always_ff (clk, rst) {
        if_reset {} else if dmem_wen && dmem_in_dram {
            if dmem_wstrb[0] {
                dram[dram_dmem_lo][7:0] = dmem_wdata[7:0];
            }
            if dmem_wstrb[1] {
                dram[dram_dmem_lo][15:8] = dmem_wdata[15:8];
            }
            if dmem_wstrb[2] {
                dram[dram_dmem_lo][23:16] = dmem_wdata[23:16];
            }
            if dmem_wstrb[3] {
                dram[dram_dmem_lo][31:24] = dmem_wdata[31:24];
            }
            if dmem_wstrb[4] {
                dram[dram_dmem_hi][7:0] = dmem_wdata[39:32];
            }
            if dmem_wstrb[5] {
                dram[dram_dmem_hi][15:8] = dmem_wdata[47:40];
            }
            if dmem_wstrb[6] {
                dram[dram_dmem_hi][23:16] = dmem_wdata[55:48];
            }
            if dmem_wstrb[7] {
                dram[dram_dmem_hi][31:24] = dmem_wdata[63:56];
            }
        }
    }

    // ============================================================
    // UART output trace + periodic PC trace
    // ============================================================
    var cycle_cnt: logic<32>;
    var prev_tp  : logic<64>;
    always_ff (clk, rst) {
        if_reset {
            cycle_cnt = 0;
            prev_tp   = 0;
        } else {
            cycle_cnt = cycle_cnt + 1;
            if uart_tx {
                $write("%c", uart_data);
            }
            // Dump printk output buffer from DRAM at console_write time
            // str=0x80a901c8: DRAM lo = {0xa901c8[24:3], 0} = {0x152039, 0} = 0x2A4072
            // Also dump str+8, str+16 for more bytes
            if cycle_cnt == 32'd7321855 {
                $display("  BUF[0]: %h %h %h %h %h %h %h %h", dram[23'h2A4072], dram[23'h2A4073], dram[23'h2A4074], dram[23'h2A4075], dram[23'h2A4076], dram[23'h2A4077], dram[23'h2A4078], dram[23'h2A4079]);
            }
            // Verify: also dump from PA 0x80a901c0 (8 bytes before str, for context)
            // DRAM lo for 0x80a901c0 = {0xa901c0[24:3], 0} = {0x152038, 0} = 0x2A4070
            if cycle_cnt == 32'd7321855 {
                $display("  BUF[-8]: %h %h", dram[23'h2A4070], dram[23'h2A4071]);
            }

            // Periodic trace every 1M cycles (with tp for context)
            if cycle_cnt[19:0] == 20'd0 {
                $display("  [%d] PC=%h SP=%h TP=%h", cycle_cnt, dbg_pc, dbg_regs[2], dbg_regs[4]);
            }
            // Detect context switch (tp change)
            if dbg_regs[4] != prev_tp && cycle_cnt >: 32'd100 {
                $display("  CTX_SW [%d] tp: %h -> %h PC=%h", cycle_cnt, prev_tp, dbg_regs[4], dbg_pc);
                prev_tp = dbg_regs[4];
            }
            // Monitor writes to PA 0x80c01180 (DRAM word 0x300460/0x300461)
            if dmem_wen && dmem_in_dram && (dmem_addr[23:3] == 21'h180230) {
                $display("  CORRUPT_WR [%d] addr=%h wdata=%h wstrb=%h stall=%h PC=%h", cycle_cnt, dmem_addr, dmem_wdata, dmem_wstrb, dbg_stall, dbg_pc);
            }
            // Monitor ALL writes to PA 0x80c01180 (the cpu_slab field of kmem_cache)
            // After cycle 5589132, the correct value is ffe000fb3060.
            // Track when it changes to find the corruption source.
            if dmem_wen && dmem_in_dram && (dmem_addr[23:3] == 21'h180230) && cycle_cnt >: 32'd5589130 {
                $display("  CPUSLAB_WR [%d] addr=%h wdata=%h wstrb=%h PC=%h stall=%h", cycle_cnt, dmem_addr, dmem_wdata, dmem_wstrb, dbg_pc, dbg_stall);
            }
            // Every-cycle DRAM snapshot to find exact corruption cycle
            // PA 0x80c01180: addr[23:3]=0x180230, dram_lo={0x180230,0}=0x300460, dram_hi={0x180230,1}=0x300461
            if cycle_cnt >: 32'd5589130 && cycle_cnt <: 32'd5589250 {
                $display("  DRAM_CHK [%d] PA_80c01180: %h_%h PC=%h", cycle_cnt, dram[22'h300461], dram[22'h300460], dbg_pc);
            }
            // Track kernel_init milestones
            if dbg_pc == 64'hffffffff800bb498 {
                $display("  >>> free_initmem_call: [%d] tp=%h", cycle_cnt, dbg_regs[4]);
            }
            if dbg_pc == 64'hffffffff800bb49c {
                $display("  >>> free_initmem_ret: [%d] tp=%h", cycle_cnt, dbg_regs[4]);
            }
            // Inside free_initmem: __set_memory stages
            if dbg_pc == 64'hffffffff80004296 {
                $display("  >>> __set_memory: [%d] tp=%h", cycle_cnt, dbg_regs[4]);
            }
            if dbg_pc == 64'hffffffff800042e2 {
                $display("  >>> sfence_vma: [%d] tp=%h", cycle_cnt, dbg_regs[4]);
            }
            if dbg_pc == 64'hffffffff800042f0 {
                $display("  >>> __set_memory_ret: [%d] tp=%h", cycle_cnt, dbg_regs[4]);
            }
            // free_reserved_area
            if dbg_pc == 64'hffffffff800468f6 {
                $display("  >>> free_reserved_area: [%d] tp=%h", cycle_cnt, dbg_regs[4]);
            }
            if dbg_pc == 64'hffffffff800469a0 {
                $display("  >>> free_reserved_area_ret: [%d] tp=%h", cycle_cnt, dbg_regs[4]);
            }
            // Track allocation functions around smpboot crash (cycles 7.22M - 7.24M)
            if dbg_pc == 64'hffffffff80048764 && cycle_cnt >: 32'd7220000 && cycle_cnt <: 32'd7240000 {
                $display("  >>> __kmalloc: [%d] a0=%h a1=%h ra=%h", cycle_cnt, dbg_regs[10], dbg_regs[11], dbg_regs[1]);
            }
            if dbg_pc == 64'hffffffff80047dc0 && cycle_cnt >: 32'd7220000 && cycle_cnt <: 32'd7240000 {
                $display("  >>> ___slab_alloc: [%d] a0=%h a1=%h a2=%h ra=%h", cycle_cnt, dbg_regs[10], dbg_regs[11], dbg_regs[12], dbg_regs[1]);
            }
            // kmem_cache_alloc at 0x8004825a
            if dbg_pc == 64'hffffffff8004825a && cycle_cnt >: 32'd7220000 && cycle_cnt <: 32'd7240000 {
                $display("  >>> kmem_cache_alloc: [%d] a0=%h a1=%h ra=%h", cycle_cnt, dbg_regs[10], dbg_regs[11], dbg_regs[1]);
            }
            // allocate_slab at 0x8004796c — trace when new slab page is allocated
            if dbg_pc == 64'hffffffff8004796c && cycle_cnt >: 32'd7220000 && cycle_cnt <: 32'd7240000 {
                $display("  >>> allocate_slab: [%d] a0=%h a1=%h a2=%h", cycle_cnt, dbg_regs[10], dbg_regs[11], dbg_regs[12]);
            }
            // __alloc_pages at 0x80045dd2 — trace page allocation
            if dbg_pc == 64'hffffffff80045dd2 && cycle_cnt >: 32'd7220000 && cycle_cnt <: 32'd7240000 {
                $display("  >>> __alloc_pages: [%d] a0=%h a1=%h a2=%h", cycle_cnt, dbg_regs[10], dbg_regs[11], dbg_regs[12]);
            }
            // Track __smpboot_create_thread entry (PC=800133aa)
            if dbg_pc == 64'hffffffff800133aa && cycle_cnt >: 32'd7200000 {
                $display("  >>> __smpboot_create_thread: [%d] a0=%h", cycle_cnt, dbg_regs[10]);
            }
            // Track kmem_cache_alloc return to __smpboot_create_thread
            // After jal kmem_cache_alloc (at 800133d2), returns to 800133d6
            // a0 = allocated address (smpboot_thread_data td)
            if dbg_pc == 64'hffffffff800133d6 && cycle_cnt >: 32'd7200000 {
                $display("  >>> kzalloc_ret: [%d] a0=%h (td)", cycle_cnt, dbg_regs[10]);
            }
            // Track the fast path cmpxchg write: sd a0, 0(a5) at 800482f6
            // This sets c->freelist = next_object
            if dbg_pc == 64'hffffffff800482f6 && cycle_cnt >: 32'd7200000 && cycle_cnt <: 32'd7230000 {
                $display("  >>> CMPXCHG_WR: [%d] a0=%h a5=%h (c->freelist=next)", cycle_cnt, dbg_regs[10], dbg_regs[15]);
            }
            // Dump DRAM at PA 0x80fb3060 (per-CPU freelist) just before the fatal allocation
            // DRAM word index: PA 0x80fb3060 → offset 0xfb3060 → lo={0xfb3060[23:3], 0}=0x1F660C, hi=0x1F660D
            if cycle_cnt == 32'd7224700 {
                // PA 0x80fb3060: addr[23:3]=0x1F660C, lo={0x1F660C,0}=0x3ECC18, hi=0x3ECC19
                $display("  DRAM_DUMP [%d] PA_80fb3060: lo=%h hi=%h (freelist)", cycle_cnt, dram[22'h3ECC18], dram[22'h3ECC19]);
                // PA 0x80fb3068: lo=0x3ECC1A, hi=0x3ECC1B
                $display("  DRAM_DUMP [%d] PA_80fb3068: lo=%h hi=%h (tid)", cycle_cnt, dram[22'h3ECC1A], dram[22'h3ECC1B]);
                // PA 0x80c01180: lo=0x300460, hi=0x300461
                $display("  DRAM_DUMP [%d] PA_80c01180: lo=%h hi=%h (cpu_slab)", cycle_cnt, dram[22'h300460], dram[22'h300461]);
            }
            // Also track all stores to PA 0x80c01180 narrowly around the crash
            if dmem_wen && dmem_in_dram && (dmem_addr[23:3] == 21'h180230) && cycle_cnt >: 32'd7224000 && cycle_cnt <: 32'd7232000 {
                $display("  >>> STORE_C01180: [%d] addr=%h wdata=%h wstrb=%h PC=%h stall=%h", cycle_cnt, dmem_addr, dmem_wdata, dmem_wstrb, dbg_pc, dbg_stall);
            }
            // After free_initmem in kernel_init
            if dbg_pc == 64'hffffffff800bb4c4 {
                $display("  >>> run_init_process: [%d] tp=%h", cycle_cnt, dbg_regs[4]);
            }
            if dbg_pc == 64'h0000000000010078 {
                $display("  >>> INIT_USER: [%d] sp=%h ra=%h a0=%h", cycle_cnt, dbg_regs[2], dbg_regs[1], dbg_regs[10]);
            }
            // memcpy entry near ring buffer copy: a0=dst, a1=src, a2=len
            if dbg_pc == 64'hffffffff800b9c50 && cycle_cnt >: 32'd7319750 && cycle_cnt <: 32'd7319880 {
                $display("  >>> memcpy: [%d] dst=%h src=%h len=%h", cycle_cnt, dbg_regs[10], dbg_regs[11], dbg_regs[12]);
            }
            // Dump dram[0x2A49E2] (PA 0x80a92788 lo word containing byte 3 = '[' or 'm')
            // Before and after the SW at cycle 7317975
            if cycle_cnt == 32'd7317974 || cycle_cnt == 32'd7317976 || cycle_cnt == 32'd7317980 || cycle_cnt == 32'd7319760 {
                $display("  DRAM_BYTE3 [%d] lo=%h hi=%h", cycle_cnt, dram[23'h2A49E2], dram[23'h2A49E3]);
            }
            // Dump ramdisk_execute_command before panic
            // PA 0x80a85368: DRAM lo = 0x2a14da
            if dbg_pc == 64'hffffffff800bb4b6 {
                $display("  >>> ramdisk_exec_cmd: [%d] a0=%h dram=%h_%h", cycle_cnt, dbg_regs[10], dram[23'h2A14DB], dram[23'h2A14DA]);
            }
            // Trace free_unref_page for the corrupted page (PA 0x81fa7f00 = VA ffe001fa7f00)
            // free_unref_page at 0x80044eba: a0 = page ptr
            if dbg_pc == 64'hffffffff80044eba && dbg_regs[10] == 64'hffffffe001fa7f00 {
                $display("  >>> FREE_PAGE: [%d] page=%h ra=%h", cycle_cnt, dbg_regs[10], dbg_regs[1]);
            }
            // Trace __rmqueue_pcplist fault: dump registers at the faulting SD
            // PC=0x80044ca6 (sd a4, 8(a3)) — a3=node->prev, a4=node->next, a5=node
            if dbg_pc == 64'hffffffff80044ca6 && cycle_cnt >: 32'd30300000 && cycle_cnt <: 32'd30330000 {
                $display("  >>> RMQUEUE_FLT: [%d] a3=%h a4=%h a5=%h s7=%h ra=%h", cycle_cnt, dbg_regs[13], dbg_regs[14], dbg_regs[15], dbg_regs[23], dbg_regs[1]);
            }
            // panic() at 0x800ba1c4: trace caller and dump message
            if dbg_pc == 64'hffffffff800ba1c4 {
                $display("  >>> PANIC: [%d] ra=%h a0=%h a1=%h", cycle_cnt, dbg_regs[1], dbg_regs[10], dbg_regs[11]);
                // Dump panic message string from stack (a1 points to it)
                // PA 0x80c37d98 → DRAM lo = 0x30df66
                $display("  PANIC_MSG: %h %h %h %h", dram[23'h30DF66], dram[23'h30DF67], dram[23'h30DF68], dram[23'h30DF69]);
            }
            if dbg_pc == 64'hffffffff80046506 {
                $display("  >>> show_free_areas: [%d] ra=%h", cycle_cnt, dbg_regs[1]);
            }
            // populate_rootfs at 0x80202160
            if dbg_pc == 64'hffffffff80202160 {
                $display("  >>> populate_rootfs: [%d]", cycle_cnt);
            }
            // unpack_to_rootfs at 0x80201cfe
            if dbg_pc == 64'hffffffff80201cfe {
                $display("  >>> unpack_to_rootfs: [%d] a0=%h a1=%h", cycle_cnt, dbg_regs[10], dbg_regs[11]);
                // Dump cpio magic from DRAM at PA 0x80409930
                // DRAM lo = 0x10264c
                $display("  CPIO_MAGIC: %h %h %h %h", dram[23'h10264C], dram[23'h10264D], dram[23'h10264E], dram[23'h10264F]);
            }
            // decompress_method at 0x8020eb2a — trace buf ptr and first byte
            if dbg_pc == 64'hffffffff8020eb2a {
                $display("  >>> decompress_method: [%d] buf=%h len=%h", cycle_cnt, dbg_regs[10], dbg_regs[11]);
            }
            // kernel_init at 0x800bb47a — trace all key PCs in the function
            if dbg_pc == 64'hffffffff800bb47a {
                $display("  >>> kernel_init: [%d]", cycle_cnt);
            }
            // kernel_init_freeable at 0x80200ba4
            if dbg_pc == 64'hffffffff80200ba4 {
                $display("  >>> kernel_init_freeable: [%d]", cycle_cnt);
            }
            // jalr to kernel_init_freeable at 0x800bb490
            if dbg_pc == 64'hffffffff800bb490 {
                $display("  >>> jalr_kinit_freeable: [%d] ra=%h", cycle_cnt, dbg_regs[1]);
            }
            // async_synchronize_full at 0x800bb494 (= jalr return point)
            if dbg_pc == 64'hffffffff800bb494 {
                $display("  >>> async_sync: [%d]", cycle_cnt);
            }
            // try_to_run_init_process at 0x800ba100
            if dbg_pc == 64'hffffffff800ba100 {
                $display("  >>> try_to_run_init_process: [%d] a0=%h", cycle_cnt, dbg_regs[10]);
            }
            if dbg_r3 == 64'hAA {
                $display("  >>> SRST: [%d]", cycle_cnt);
            }
        }
    }

    // ============================================================
    // Debug outputs
    // ============================================================
    assign o_r1   = dbg_regs[9]; // x9
    assign o_r2   = dbg_regs[11]; // x11
    assign o_r3   = dbg_r3; // x3 (0xAA=success)
    assign o_pass = dbg_r3 == 64'hAA;

}

#[test(test_linux_boot)]
module test_linux_boot {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_linux_boot_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (50000000);
        $display  ("x9=%h x11=%h x3=%h pass=%b", r1, r2, r3, pass);
        $assert   (pass, "Real Linux boot: expected x3=0xAA (SBI SRST shutdown)");
        $display  ("Real Linux kernel boot test passed");
        $finish   ();
    }
}
