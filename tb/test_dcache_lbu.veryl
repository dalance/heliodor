// Test: dcache miss + LBU/LHU/LWU byte extraction
// Verifies that byte-select logic works correctly after a dcache fill.
// Program stores 0x0807060504030201 to 0x1000, then reads back with
// LBU/LHU/LWU/LD (all trigger dcache miss since SD is no-write-allocate).
module test_dcache_lbu_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var uart_tx   : logic;
    var uart_data : logic<8>;
    var _dbg_stall: logic<8>;

    inst dut: heliodor_top (
        clk, rst,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
        o_uart_tx    : uart_tx       ,
        o_uart_data  : uart_data     ,
        o_dbg_stall  : _dbg_stall    ,
    );

    // Instruction memory: 4K words
    var imem: logic<32> [4096];
    initial {
        $readmemh("test/hex/dcache_lbu.hex", imem);
    }
    assign imem_rdata = imem[imem_addr[13:2]];

    // Data memory: 4K doublewords (32 KB)
    var dmem: logic<64> [4096];
    always_ff (clk, rst) {
        if_reset { for i: i32 in 0..4096 { dmem[i] = 64'd0; } }
        else if dmem_wen { dmem[dmem_addr[14:3]] = dmem_wdata; }
    }
    assign dmem_rdata = dmem[dmem_addr[14:3]];

    // Check register values after program completes (self-loop at end)
    // x3 = LBU byte 0 = 0x01
    // x4 = LBU byte 1 = 0x02
    // x5 = LBU byte 7 = 0x08
    // x6 = LHU bytes 0-1 = 0x0201
    // x7 = LWU bytes 0-3 = 0x04030201
    // x8 = LD all bytes = 0x0807060504030201
    let x3_ok: logic = dbg_regs[3] == 64'h01;
    let x4_ok: logic = dbg_regs[4] == 64'h02;
    let x5_ok: logic = dbg_regs[5] == 64'h08;
    let x6_ok: logic = dbg_regs[6] == 64'h0201;
    let x7_ok: logic = dbg_regs[7] == 64'h04030201;
    let x8_ok: logic = dbg_regs[8] == 64'h0807060504030201;

    assign o_pass = x3_ok && x4_ok && x5_ok && x6_ok && x7_ok && x8_ok;
    assign o_r1   = dbg_regs[3]; // LBU byte 0
    assign o_r2   = dbg_regs[4]; // LBU byte 1
    assign o_r3   = dbg_regs[5]; // LBU byte 7
}

#[test(test_dcache_lbu)]
module test_dcache_lbu {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_dcache_lbu_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(10000);
        $display(r1, r2, r3, pass);
        $assert(pass, "dcache LBU: byte extraction from dcache miss fill failed");
        $display("dcache LBU byte extraction test passed");
        $finish();
    }
}
