// Integration test: load program from hex file and run through CPU pipeline.
// This is the foundation for running riscv-tests and larger programs.
module test_hex_loader_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var _iptw_addr: logic<64>;
    var _iptw_req : logic;

    inst dut: heliodor_top (
        clk, rst,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_iptw_addr  : _iptw_addr    ,
        o_iptw_req   : _iptw_req     ,
        i_iptw_rdata : 64'd0         ,
        i_uart_rx_data : 8'd0        ,
        i_uart_rx_valid: 1'b0        ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
    );

    // Instruction memory: 4096 words (16 KB), loaded from hex file
    var imem: logic<32> [4096];
    initial {
        $readmemh("test/hex/basic_alu.hex", imem);
    }
    assign imem_rdata = imem[imem_addr[13:2]];

    // Data memory: 1024 doublewords (8 KB) at address 0x80000000+
    var dmem: logic<64> [1024];
    always_ff (clk, rst) {
        if_reset {
            for i: i32 in 0..1024 { dmem[i] = 64'd0; }
        } else if dmem_wen {
            dmem[dmem_addr[12:3]] = dmem_wdata;
        }
    }
    assign dmem_rdata = dmem[dmem_addr[12:3]];

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;

    // Check expected results:
    //   x1 = 0x12345678 (LUI + ADDI)
    //   x2 = 0x12345679 (ADDI x2, x1, 1)
    assign o_pass = dbg_r1 == 64'h12345678
                 && dbg_r2 == 64'h12345679;
}

#[test(test_hex_loader)]
module test_hex_loader {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_hex_loader_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(100);
        $display(r1, r2, pass);
        $assert(pass, "hex loader: x1=0x12345678 x2=0x12345679 failed");
        $display("hex loader test passed");
        $finish();
    }
}
