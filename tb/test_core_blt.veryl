// Integration test for BLT (branch less than, signed)
module test_core_blt_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;

    inst dut: heliodor_top (
        clk                          ,
        rst                          ,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
    );

    assign dmem_rdata = 64'd0;

    // Program: test BLT (signed less-than, taken)
    //   0x00: ADDI  x1, x0, -1     -> x1 = -1 (0xFFFF...FFFF)
    //   0x04: ADDI  x2, x0, 1      -> x2 = 1
    //   0x08: BLT   x1, x2, +8     -> taken (-1 < 1), jump to 0x10
    //   0x0C: ADDI  x3, x0, 99     -> SKIPPED (branch shadow)
    //   0x10: ADDI  x3, x0, 42     -> x3 = 42 (branch target)
    //   0x14+: NOP
    //
    // Encoding:
    //   ADDI x1, x0, -1: imm=0xFFF, rs1=0, f3=000, rd=1, op=0010011
    //     = 0xFFF00093
    //   ADDI x2, x0, 1:  0x00100113
    //   BLT  x1, x2, +8: B-type, funct3=100, imm=8
    //     imm[12|10:5]=0000000, rs2=2, rs1=1, funct3=100, imm[4:1|11]=0100_0, op=1100011
    //     = 0x0020C463
    //   ADDI x3, x0, 99: 0x06300193
    //   ADDI x3, x0, 42: 0x02A00193
    always_comb {
        case imem_addr[7:0] {
            8'h00:   imem_rdata = 32'hFFF00093; // ADDI x1, x0, -1
            8'h04:   imem_rdata = 32'h00100113; // ADDI x2, x0, 1
            8'h08:   imem_rdata = 32'h0020C463; // BLT  x1, x2, +8
            8'h0C:   imem_rdata = 32'h06300193; // ADDI x3, x0, 99 (skipped)
            8'h10:   imem_rdata = 32'h02A00193; // ADDI x3, x0, 42 (target)
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x1=-1, x2=1, x3=42 (not 99)
    assign o_pass = dbg_r1 == 64'hFFFFFFFF_FFFFFFFF
                 && dbg_r2 == 64'd1
                 && dbg_r3 == 64'd42;
}

#[test(test_core_blt)]
module test_core_blt {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_core_blt_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(45);
        $display(r1, r2, r3, pass);
        $assert(pass, "BLT register values mismatch");
        $display("BLT integration test passed");
        $finish();
    }
}
