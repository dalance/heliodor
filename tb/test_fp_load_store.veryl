// Integration test for FP load/store: FSD + FLD through the pipeline
// Tests that FP register file is correctly wired and FP load/store
// instructions work through the existing memory path.
module test_fp_load_store_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var _iptw_addr: logic<64>     ;
    var _iptw_req : logic         ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : _iptw_addr,
        o_iptw_req     : _iptw_req ,
        i_iptw_rdata   : 64'd0     ,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
    );

    // Simple 64-byte data memory
    var mem: logic<64> [8];
    always_ff (clk, rst) {
        if_reset {
            for i: i32 in 0..8 {
                mem[i] = 64'd0;
            }
        } else if dmem_wen {
            mem[dmem_addr[5:3]] = dmem_wdata;
        }
    }
    assign dmem_rdata = mem[dmem_addr[5:3]];

    // Program: Test FLD/FSD via integer registers to verify data path
    //
    //   0x00: ADDI x1, x0, 0x100     # x1 = 0x100 (data memory address)
    //   0x04-0x0C: NOP
    //   0x10: LUI x2, 0x40140         # x2 = 0x40140000 (upper bits of 5.0 double)
    //                                 # Actually: double 5.0 = 0x4014000000000000
    //                                 # LUI x2, 0x40140 → x2 = 0x40140 << 12 = 0x40140000
    //   0x14-0x1C: NOP
    //   0x20: SLLI x2, x2, 20        # x2 = 0x40140000 << 20 = 0x4014000000000000 (double 5.0)
    //   0x24-0x2C: NOP
    //   0x30: SD x2, 0(x1)           # Store 5.0 to memory at 0x100
    //   0x34-0x3C: NOP
    //   0x40: FLD f1, 0(x1)          # Load 5.0 from memory into f1
    //         FLD: opcode=0000111, funct3=011, rd=f1(1), rs1=x1(1), imm=0
    //         Encoding: 0000000_00000_00001_011_00001_0000111 = 0x0000B087
    //   0x44-0x4C: NOP
    //   0x50: FSD f1, 8(x1)          # Store f1 back to memory at 0x108
    //         FSD: opcode=0100111, funct3=011, rs1=x1(1), rs2=f1(1), imm=8
    //         Encoding: 0000000_00001_00001_011_01000_0100111 = 0x0010B427
    //   0x54-0x5C: NOP
    //   0x60: LD x3, 8(x1)           # Load back from 0x108 into x3
    //   0x64-0x6C: NOP
    //
    // If FP load/store works: x3 = 0x4014000000000000 (double 5.0)
    // We also check x2 for the expected pattern.

    always_comb {
        case imem_addr[7:0] {
            8'h00  : imem_rdata = 32'h10000093; // ADDI x1, x0, 0x100
            8'h04  : imem_rdata = 32'h00000013;
            8'h08  : imem_rdata = 32'h00000013;
            8'h0C  : imem_rdata = 32'h00000013;
            8'h10  : imem_rdata = 32'h40140137; // LUI x2, 0x40140
            8'h14  : imem_rdata = 32'h00000013;
            8'h18  : imem_rdata = 32'h00000013;
            8'h1C  : imem_rdata = 32'h00000013;
            8'h20  : imem_rdata = 32'h02011113; // SLLI x2, x2, 32
            8'h24  : imem_rdata = 32'h00000013;
            8'h28  : imem_rdata = 32'h00000013;
            8'h2C  : imem_rdata = 32'h00000013;
            8'h30  : imem_rdata = 32'h0020B023; // SD x2, 0(x1)
            8'h34  : imem_rdata = 32'h00000013;
            8'h38  : imem_rdata = 32'h00000013;
            8'h3C  : imem_rdata = 32'h00000013;
            8'h40  : imem_rdata = 32'h0000B087; // FLD f1, 0(x1)
            8'h44  : imem_rdata = 32'h00000013;
            8'h48  : imem_rdata = 32'h00000013;
            8'h4C  : imem_rdata = 32'h00000013;
            8'h50  : imem_rdata = 32'h0010B427; // FSD f1, 8(x1)
            8'h54  : imem_rdata = 32'h00000013;
            8'h58  : imem_rdata = 32'h00000013;
            8'h5C  : imem_rdata = 32'h00000013;
            8'h60  : imem_rdata = 32'h0080B183; // LD x3, 8(x1)
            8'h64  : imem_rdata = 32'h00000013;
            8'h68  : imem_rdata = 32'h0000006F; // JAL x0, 0 (loop)
            default: imem_rdata = 32'h00000013;
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x2 = 0x4014000000000000 (double 5.0, stored to memory)
    // x3 = 0x4014000000000000 (loaded back via FLD f1 → FSD f1 → LD x3)
    assign o_pass = dbg_r2 == 64'h4014000000000000 && dbg_r3 == 64'h4014000000000000;
}

#[test(test_fp_load_store)]
module test_fp_load_store {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_fp_load_store_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (300);
        $display  (r1, r2, r3, pass);
        $assert   (pass, "FP load/store test failed");
        $display  ("FP load/store test passed");
        $finish   ();
    }
}
