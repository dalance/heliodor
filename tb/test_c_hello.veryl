// First C program on heliodor: bare-metal Hello World compiled with GCC.
// Program writes "Hello from C!\nfib(10)=55\nfib(20)=6765\n" to UART.
// Validates: C startup (stack setup, BSS clear), function calls,
// integer division (print_dec), loops, and UART MMIO from compiled code.
module test_c_hello_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var uart_tx   : logic;
    var uart_data : logic<8>;
    var _dbg_stall: logic<8>;

    inst dut: heliodor_top (
        clk, rst,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
        o_uart_tx    : uart_tx       ,
        o_uart_data  : uart_data     ,
        o_dbg_stall  : _dbg_stall    ,
    );

    // Flat memory: 4K doublewords (32 KB).
    // Instruction port reads 32-bit words, data port reads/writes 64-bit.
    // $readmemh initializes instruction words; data port writes update in place.
    var imem: logic<32> [8192];
    initial {
        $readmemh("test/hex/hello_c.hex", imem);
    }
    assign imem_rdata = imem[imem_addr[14:2]];

    // Data memory: 4K doublewords
    var dmem: logic<64> [4096];
    always_ff (clk, rst) {
        if_reset { for i: i32 in 0..4096 { dmem[i] = 64'd0; } }
        else if dmem_wen { dmem[dmem_addr[14:3]] = dmem_wdata; }
    }
    assign dmem_rdata = dmem[dmem_addr[14:3]];

    // Capture UART output into buffer (up to 64 bytes)
    var tx_buf: logic<8> [64];
    var tx_count: logic<7>;
    always_ff (clk, rst) {
        if_reset {
            for i: i32 in 0..64 { tx_buf[i] = 8'd0; }
            tx_count = 7'd0;
        } else if uart_tx && (tx_count <: 7'd64) {
            tx_buf[tx_count] = uart_data;
            tx_count = tx_count + 7'd1;
        }
    }

    assign o_r1 = {57'd0, tx_count};
    assign o_r2 = dbg_pc;
    assign o_r3 = dbg_r3;

    // Expected: "Hi!\n=0000000000000037\n" (22 bytes)
    assign o_pass = tx_count >= 7'd22
                 && tx_buf[0]  == 8'h48   // H
                 && tx_buf[1]  == 8'h69   // i
                 && tx_buf[2]  == 8'h21   // !
                 && tx_buf[3]  == 8'h0A   // \n
                 && tx_buf[4]  == 8'h3D   // =
                 && tx_buf[21] == 8'h0A;  // \n
}

#[test(test_c_hello)]
module test_c_hello {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_c_hello_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(100000);
        $display(r1, r2, r3, pass);
        $assert(pass, "C hello: expected 'Hello from C!\\nfib(10)=55\\nfib(20)=6765\\n'");
        $display("C Hello World test passed");
        $finish();
    }
}
