// Regression test: JAL with offset=0 ("j .") must loop, not fall through.
// Verifies that the pipeline correctly handles self-loop JAL instructions.
module test_jal_selfloop_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var _iptw_addr: logic<64>;
    var _iptw_req : logic;

    inst dut: heliodor_top (
        clk                          ,
        rst                          ,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_iptw_addr  : _iptw_addr    ,
        o_iptw_req   : _iptw_req     ,
        i_iptw_rdata : 64'd0         ,
        i_uart_rx_data : 8'd0        ,
        i_uart_rx_valid: 1'b0        ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
    );

    assign dmem_rdata = 64'd0;

    // Program:
    //   0x00: ADDI  x3, x0, 0xAA   -> x3 = 0xAA (success marker)
    //   0x04: JAL   x0, 0           -> "j ." self-loop (should stay here)
    //   0x08: ADDI  x3, x0, 0xBB   -> x3 = 0xBB (MUST NOT execute)
    //   0x0C+: NOP
    //
    // Encoding:
    //   ADDI x3, x0, 0xAA: imm=0xAA, rs1=0, f3=000, rd=3, op=0010011
    //     = 0x0AA00193
    //   JAL x0, 0: all imm bits = 0, rd=0, op=1101111
    //     = 0x0000006F
    //   ADDI x3, x0, 0xBB: imm=0xBB, rs1=0, f3=000, rd=3, op=0010011
    //     = 0x0BB00193
    always_comb {
        case imem_addr[7:0] {
            8'h00:   imem_rdata = 32'h0AA00193; // ADDI x3, x0, 0xAA
            8'h04:   imem_rdata = 32'h0000006F; // JAL  x0, 0 (j .)
            8'h08:   imem_rdata = 32'h0BB00193; // ADDI x3, x0, 0xBB
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x3 must be 0xAA (not 0xBB — if it is, "j ." fell through)
    assign o_pass = dbg_r3 == 64'hAA;
}

#[test(test_jal_selfloop)]
module test_jal_selfloop {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_jal_selfloop_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(30);
        $display(r1, r2, r3, pass);
        $assert(pass, "JAL self-loop: x3 should be 0xAA (j . fell through if 0xBB)");
        $display("JAL self-loop (j .) test passed");
        $finish();
    }
}
