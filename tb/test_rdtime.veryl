// Regression test: rdtime must return correct mtime value even after
// div rd,rd,zero writes -1 to the same destination register.
// Reproduces Linux __delay loop pattern where rdtime gets stale value.
module test_rdtime_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var _iptw_addr: logic<64>     ;
    var _iptw_req : logic         ;
    var _dbg_stall: logic<8>      ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : _iptw_addr,
        o_iptw_req     : _iptw_req ,
        i_iptw_rdata   : 64'd0     ,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
        o_dbg_stall    : _dbg_stall,
    );

    var code_mem: logic<32> [256];
    // Large DRAM to reproduce comb ordering issue
    var dram: logic<32> [4194304];
    initial {
        $readmemh("test/hex/rdtime_test.hex", code_mem);
    }
    assign imem_rdata = code_mem[imem_addr[9:2]];
    // DRAM read (creates comb dependency on dmem_addr)
    let dram_lo: logic<22> = {dmem_addr[23:3], 1'b0};
    let dram_hi: logic<22> = {dmem_addr[23:3], 1'b1};
    assign dmem_rdata = if dmem_addr[31] ? {dram[dram_hi], dram[dram_lo]} : 64'd0;

    assign o_r1   = dbg_r1;
    assign o_r2   = dbg_r2;
    assign o_r3   = dbg_r3;
    assign o_pass = dbg_r3 == 64'hAA;
}

#[test(test_rdtime)]
module test_rdtime {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_rdtime_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (2000);
        $display  ("x3=%h pass=%b", r3, pass);
        $assert   (pass, "rdtime test: expected x3=0xAA (rdtime returns correct values after div)");
        $display  ("rdtime regression test passed");
        $finish   ();
    }
}
