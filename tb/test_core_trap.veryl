// Integration test for ECALL → mtvec trap entry and MRET → mepc return
module test_core_trap_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;

    inst dut: heliodor_top (
        clk                          ,
        rst                          ,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
    );

    assign dmem_rdata = 64'd0;

    // Program: ECALL trap entry → trap handler → MRET return
    //
    // --- Main code ---
    //   0x00: ADDI x1, x0, 0x80       # x1 = 0x80 (trap handler address)
    //   0x04: NOP (3 NOPs for x1 writeback)
    //   0x08: NOP
    //   0x0C: NOP
    //   0x10: CSRRW x0, mtvec, x1     # mtvec = 0x80
    //   0x14: NOP (3 NOPs for CSR writeback)
    //   0x18: NOP
    //   0x1C: NOP
    //   0x20: ADDI x1, x0, 1          # x1 = 1 (marker: before trap)
    //   0x24: NOP
    //   0x28: NOP
    //   0x2C: NOP
    //   0x30: ECALL                    # Trap! → PC = mtvec = 0x80
    //                                  # mepc = 0x30, mcause = 11
    //   --- after MRET returns to 0x34 ---
    //   0x34: ADDI x3, x0, 3          # x3 = 3 (marker: returned from trap)
    //   0x38+: NOP...
    //
    // --- Trap handler at 0x80 ---
    //   0x80: ADDI x2, x0, 2          # x2 = 2 (marker: in trap handler)
    //   0x84: NOP (3 NOPs)
    //   0x88: NOP
    //   0x8C: NOP
    //   0x90: CSRRS x20, mepc, x0     # x20 = mepc (= 0x30)
    //   0x94: NOP
    //   0x98: NOP
    //   0x9C: NOP
    //   0xA0: ADDI x20, x20, 4        # x20 = 0x34 (skip ECALL)
    //   0xA4: NOP
    //   0xA8: NOP
    //   0xAC: NOP
    //   0xB0: CSRRW x0, mepc, x20     # mepc = 0x34
    //   0xB4: NOP
    //   0xB8: NOP
    //   0xBC: NOP
    //   0xC0: MRET                     # PC = mepc = 0x34

    always_comb {
        case imem_addr[7:0] {
            // Main code
            8'h00:   imem_rdata = 32'h08000093; // ADDI x1, x0, 0x80
            8'h04:   imem_rdata = 32'h00000013; // NOP
            8'h08:   imem_rdata = 32'h00000013; // NOP
            8'h0C:   imem_rdata = 32'h00000013; // NOP
            8'h10:   imem_rdata = 32'h30509073; // CSRRW x0, mtvec, x1
            8'h14:   imem_rdata = 32'h00000013; // NOP
            8'h18:   imem_rdata = 32'h00000013; // NOP
            8'h1C:   imem_rdata = 32'h00000013; // NOP
            8'h20:   imem_rdata = 32'h00100093; // ADDI x1, x0, 1
            8'h24:   imem_rdata = 32'h00000013; // NOP
            8'h28:   imem_rdata = 32'h00000013; // NOP
            8'h2C:   imem_rdata = 32'h00000013; // NOP
            8'h30:   imem_rdata = 32'h00000073; // ECALL
            8'h34:   imem_rdata = 32'h00300193; // ADDI x3, x0, 3
            8'h38:   imem_rdata = 32'h00000013; // NOP
            // Trap handler at 0x80
            8'h80:   imem_rdata = 32'h00200113; // ADDI x2, x0, 2
            8'h84:   imem_rdata = 32'h00000013; // NOP
            8'h88:   imem_rdata = 32'h00000013; // NOP
            8'h8C:   imem_rdata = 32'h00000013; // NOP
            8'h90:   imem_rdata = 32'h34102A73; // CSRRS x20, mepc, x0
            8'h94:   imem_rdata = 32'h00000013; // NOP
            8'h98:   imem_rdata = 32'h00000013; // NOP
            8'h9C:   imem_rdata = 32'h00000013; // NOP
            8'hA0:   imem_rdata = 32'h004A0A13; // ADDI x20, x20, 4
            8'hA4:   imem_rdata = 32'h00000013; // NOP
            8'hA8:   imem_rdata = 32'h00000013; // NOP
            8'hAC:   imem_rdata = 32'h00000013; // NOP
            8'hB0:   imem_rdata = 32'h341A1073; // CSRRW x0, mepc, x20
            8'hB4:   imem_rdata = 32'h00000013; // NOP
            8'hB8:   imem_rdata = 32'h00000013; // NOP
            8'hBC:   imem_rdata = 32'h00000013; // NOP
            8'hC0:   imem_rdata = 32'h30200073; // MRET
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x1 = 1 (set before ECALL)
    // x2 = 2 (set in trap handler)
    // x3 = 3 (set after MRET return)
    assign o_pass = dbg_r1 == 64'd1
                 && dbg_r2 == 64'd2
                 && dbg_r3 == 64'd3;
}

#[test(test_core_trap)]
module test_core_trap {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_core_trap_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(500);
        $display(r1, r2, r3, pass);
        $assert(pass, "Trap test failed");
        $display("ECALL/MRET trap test passed");
        $finish();
    }
}
