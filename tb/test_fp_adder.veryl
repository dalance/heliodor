// Standalone test for fp_adder module (no CPU pipeline)
// Tests: 5.0 + 5.0 = 10.0
module test_fp_adder_harness (
    clk     : input  clock    ,
    rst     : input  reset    ,
    o_result: output logic<64>,
    o_fflags: output logic<5> ,
    o_pass  : output logic    ,
) {
    var a_reg: logic<64>;
    always_ff (clk, rst) {
        if_reset {
            a_reg = 64'd0;
        } else {
            a_reg = 64'h4014000000000000;
        } // 5.0
    }

    var add_result: logic<64>;
    var add_fflags: logic<5> ;

    inst u_adder: fp_adder (
        i_a     : a_reg     ,
        i_b     : a_reg     ,
        i_sub   : 1'b0      ,
        i_rm    : 3'b000    ,
        o_result: add_result,
        o_fflags: add_fflags,
    );

    assign o_result = add_result;
    assign o_fflags = add_fflags;
    assign o_pass   = add_result == 64'h4024000000000000; // 10.0
}

#[test(test_fp_adder)]
module test_fp_adder {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var result: logic<64>;
    var fflags: logic<5> ;
    var pass  : logic    ;

    inst harness: test_fp_adder_harness (
        clk             ,
        rst             ,
        o_result: result,
        o_fflags: fflags,
        o_pass  : pass  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (10);
        $display  (result, fflags, pass);
        $assert   (pass, "fp_adder 5.0+5.0 should be 10.0");
        $finish   ();
    }
}
