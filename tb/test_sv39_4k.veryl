// Sv39 MMU 4KB page test: 3-level page table walk with store and load.
// M-mode builds a 3-level page table (L2→L1→L0), enables Sv39, MRETs to S-mode.
// S-mode writes and reads data through 4KB page translations.
module test_sv39_4k_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var iptw_addr : logic<64>     ;
    var iptw_req  : logic         ;
    var iptw_rdata: logic<64>     ;
    var uart_tx   : logic         ;
    var uart_data : logic<8>      ;
    var _dbg_stall: logic<8>      ;

    inst dut: heliodor_top (
        clk                     ,
        rst                     ,
        o_imem_addr : imem_addr ,
        i_imem_rdata: imem_rdata,
        o_imem_ren  : imem_ren  ,
        o_iptw_addr : iptw_addr ,
        o_iptw_req  : iptw_req  ,
        i_iptw_rdata: iptw_rdata,
        o_dmem_addr : dmem_addr ,
        o_dmem_wdata: dmem_wdata,
        i_dmem_rdata: dmem_rdata,
        o_dmem_wen  : dmem_wen  ,
        o_dmem_ren  : dmem_ren  ,
        o_dmem_wstrb: dmem_wstrb,
        o_dbg_regs  : dbg_regs  ,
        o_dbg_pc    : dbg_pc    ,
        o_dbg_pass  : dbg_pass  ,
        o_dbg_r1    : dbg_r1    ,
        o_dbg_r2    : dbg_r2    ,
        o_dbg_r3    : dbg_r3    ,
        i_ext_irq   : 32'd0     ,
        o_uart_tx   : uart_tx   ,
        o_uart_data : uart_data ,
        o_dbg_stall : _dbg_stall,
    );

    // Code memory (read-only, 256 words = 1KB, mapped to 0x0000-0x03FF)
    var code_mem: logic<32> [256];
    initial {
        $readmemh("test/hex/sv39_4k_test.hex", code_mem);
    }

    // Data memory (read-write, 3072 words = 12KB, mapped to 0x1000-0x3FFF)
    // 0x1000-0x1FFF: L2 page table (root)
    // 0x2000-0x2FFF: L1 page table
    // 0x3000-0x3FFF: L0 page table + test data area (0x3800+)
    var data_mem: logic<32> [3072];

    // Stack memory (read-write, 512 words, mapped to 0x7000-0x8FFF)
    var stk_mem: logic<32> [512];

    // Instruction read
    assign imem_rdata = code_mem[imem_addr[9:2]];

    // Instruction PTW read (64-bit, same address decode as dmem)
    let iptw_is_data: logic = iptw_addr[15:14] == 2'b00 && (iptw_addr[13:12] == 2'b01 || iptw_addr[13:12] == 2'b10 || iptw_addr[13:12] == 2'b11);
    let iptw_data_offset: logic<14> = {iptw_addr[13:12] - 2'd1, iptw_addr[11:0]};
    let iptw_dw_lo      : logic<12> = {iptw_data_offset[13:3], 1'b0};
    let iptw_dw_hi      : logic<12> = {iptw_data_offset[13:3], 1'b1};
    assign iptw_rdata       = if iptw_is_data ?
        {data_mem[iptw_dw_hi], data_mem[iptw_dw_lo]}
    :
        {code_mem[{iptw_addr[9:3], 1'b1}], code_mem[{iptw_addr[9:3], 1'b0}]}
    ;

    // Address decode
    let is_data: logic = dmem_addr[15:14] == 2'b00 && (dmem_addr[13:12] == 2'b01 // 0x1000-0x1FFF
     || dmem_addr[13:12] == 2'b10 // 0x2000-0x2FFF
     || dmem_addr[13:12] == 2'b11); // 0x3000-0x3FFF
    let is_stk: logic = dmem_addr[15:13] == 3'b011 // 0x6000-0x7FFF
     || dmem_addr[15:13] == 3'b100; // 0x8000-0x9FFF

    // Data memory word indices (12KB = 3072 words, addr 0x1000-0x3FFF)
    // Subtract 0x1000 base: use addr[13:0] - 0x1000, then divide by 4.
    // addr[13:0] with base 0x1000: offset = addr - 0x1000 = addr[11:0] when addr[12]=0
    // For 0x1000-0x1FFF: offset 0x000-0xFFF, word index 0-0x3FF
    // For 0x2000-0x2FFF: offset 0x1000-0x1FFF, word index 0x400-0x7FF
    // For 0x3000-0x3FFF: offset 0x2000-0x2FFF, word index 0x800-0xBFF
    // offset in bytes = {dmem_addr[13:12]-1, dmem_addr[11:0]}
    let data_offset: logic<14> = {dmem_addr[13:12] - 2'd1, dmem_addr[11:0]};
    let data_dw_lo : logic<12> = {data_offset[13:3], 1'b0};
    let data_dw_hi : logic<12> = {data_offset[13:3], 1'b1};
    let stk_dw_lo  : logic<9>  = {dmem_addr[10:3], 1'b0};
    let stk_dw_hi  : logic<9>  = {dmem_addr[10:3], 1'b1};
    let code_dw_lo : logic<8>  = {dmem_addr[9:3], 1'b0};
    let code_dw_hi : logic<8>  = {dmem_addr[9:3], 1'b1};

    // Data read (64-bit)
    assign dmem_rdata = if is_data ?
        {data_mem[data_dw_hi], data_mem[data_dw_lo]}
    : if is_stk ?
        {stk_mem[stk_dw_hi], stk_mem[stk_dw_lo]}
    :
        {code_mem[code_dw_hi], code_mem[code_dw_lo]}
    ;

    // Data write
    always_ff (clk, rst) {
        if_reset {} else if dmem_wen && dmem_addr[31:16] == 16'd0 {
            if is_data {
                if dmem_wstrb[3:0] != 4'd0 {
                    var lo                  : logic<32>;
                    lo                   = data_mem[data_dw_lo];
                    if dmem_wstrb[0] {
                        lo[7:0]              = dmem_wdata[7:0];
                    }
                    if dmem_wstrb[1] {
                        lo[15:8]             = dmem_wdata[15:8];
                    }
                    if dmem_wstrb[2] {
                        lo[23:16]            = dmem_wdata[23:16];
                    }
                    if dmem_wstrb[3] {
                        lo[31:24]            = dmem_wdata[31:24];
                    }
                    data_mem[data_dw_lo] = lo;
                }
                if dmem_wstrb[7:4] != 4'd0 {
                    var hi                  : logic<32>;
                    hi                   = data_mem[data_dw_hi];
                    if dmem_wstrb[4] {
                        hi[7:0]              = dmem_wdata[39:32];
                    }
                    if dmem_wstrb[5] {
                        hi[15:8]             = dmem_wdata[47:40];
                    }
                    if dmem_wstrb[6] {
                        hi[23:16]            = dmem_wdata[55:48];
                    }
                    if dmem_wstrb[7] {
                        hi[31:24]            = dmem_wdata[63:56];
                    }
                    data_mem[data_dw_hi] = hi;
                }
            } else if is_stk {
                if dmem_wstrb[3:0] != 4'd0 {
                    var lo                : logic<32>;
                    lo                 = stk_mem[stk_dw_lo];
                    if dmem_wstrb[0] {
                        lo[7:0]            = dmem_wdata[7:0];
                    }
                    if dmem_wstrb[1] {
                        lo[15:8]           = dmem_wdata[15:8];
                    }
                    if dmem_wstrb[2] {
                        lo[23:16]          = dmem_wdata[23:16];
                    }
                    if dmem_wstrb[3] {
                        lo[31:24]          = dmem_wdata[31:24];
                    }
                    stk_mem[stk_dw_lo] = lo;
                }
                if dmem_wstrb[7:4] != 4'd0 {
                    var hi                : logic<32>;
                    hi                 = stk_mem[stk_dw_hi];
                    if dmem_wstrb[4] {
                        hi[7:0]            = dmem_wdata[39:32];
                    }
                    if dmem_wstrb[5] {
                        hi[15:8]           = dmem_wdata[47:40];
                    }
                    if dmem_wstrb[6] {
                        hi[23:16]          = dmem_wdata[55:48];
                    }
                    if dmem_wstrb[7] {
                        hi[31:24]          = dmem_wdata[63:56];
                    }
                    stk_mem[stk_dw_hi] = hi;
                }
            }
        }
    }

    // x3 = 0xAA (pass) or 0xBB (fail)
    assign o_r1 = dbg_regs[3];
    assign o_r2 = dbg_regs[5]; // t0
    assign o_r3 = dbg_regs[7]; // t2

    // Pass: x3 = 0xAA
    assign o_pass = dbg_regs[3] == 64'hAA;
}

#[test(test_sv39_4k)]
module test_sv39_4k {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_sv39_4k_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (100000);
        $display  ("x3=%h t0=%h t2=%h pass=%b", r1, r2, r3, pass);
        $assert   (pass, "Sv39 4KB: expected x3=0xAA (3-level PTW + store/load passed)");
        $display  ("Sv39 4KB page test passed");
        $finish   ();
    }
}
