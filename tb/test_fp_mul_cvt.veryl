// Integration test: FMUL.D, FCVT.D.W, FCVT.W.D, FMADD.D through CPU pipeline
// Test: 3.0 * 4.0 = 12.0, FCVT.D.W(7) = 7.0, FCVT.W.D(12.0) = 12
module test_fp_mul_cvt_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var _iptw_addr: logic<64>;
    var _iptw_req : logic;

    inst dut: heliodor_top (
        clk, rst,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_iptw_addr  : _iptw_addr    ,
        o_iptw_req   : _iptw_req     ,
        i_iptw_rdata : 64'd0         ,
        i_uart_rx_data : 8'd0        ,
        i_uart_rx_valid: 1'b0        ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
    );

    // Simple data memory (256 bytes = 32 doublewords)
    var mem: logic<64> [32];
    always_ff (clk, rst) {
        if_reset { for i: i32 in 0..32 { mem[i] = 64'd0; } }
        else if dmem_wen { mem[dmem_addr[7:3]] = dmem_wdata; }
    }
    assign dmem_rdata = mem[dmem_addr[7:3]];

    // Test program:
    //   x1 = 0x100 (data base)
    //   Store 3.0 to mem[0x100], 4.0 to mem[0x108]
    //   FLD f1, 0(x1)  → f1 = 3.0
    //   FLD f2, 8(x1)  → f2 = 4.0
    //   FMUL.D f3, f1, f2  → f3 = 12.0
    //   FSD f3, 16(x1) → mem[0x110]
    //   LD x2, 16(x1)  → x2 = FMUL result (expect 12.0 = 0x4028000000000000)
    //   ADDI x4, x0, 7
    //   FCVT.D.W f4, x4 → f4 = 7.0
    //   FSD f4, 24(x1) → mem[0x118]
    //   LD x3, 24(x1)  → x3 = FCVT result (expect 7.0 = 0x401C000000000000)
    always_comb {
        case imem_addr[8:0] {
            // x1 = 0x100
            9'h000: imem_rdata = 32'h10000093; // ADDI x1, x0, 0x100
            9'h004: imem_rdata = 32'h00000013; // NOP
            9'h008: imem_rdata = 32'h00000013;
            9'h00C: imem_rdata = 32'h00000013;
            // x2 = 3.0 (0x4008000000000000)
            9'h010: imem_rdata = 32'h40080137; // LUI x2, 0x40080
            9'h014: imem_rdata = 32'h00000013;
            9'h018: imem_rdata = 32'h00000013;
            9'h01C: imem_rdata = 32'h00000013;
            9'h020: imem_rdata = 32'h02011113; // SLLI x2, x2, 32
            9'h024: imem_rdata = 32'h00000013;
            9'h028: imem_rdata = 32'h00000013;
            9'h02C: imem_rdata = 32'h00000013;
            // SD x2, 0(x1)
            9'h030: imem_rdata = 32'h0020B023; // SD x2, 0(x1)
            9'h034: imem_rdata = 32'h00000013;
            9'h038: imem_rdata = 32'h00000013;
            9'h03C: imem_rdata = 32'h00000013;
            // x3 = 4.0 (0x4010000000000000)
            9'h040: imem_rdata = 32'h401001B7; // LUI x3, 0x40100
            9'h044: imem_rdata = 32'h00000013;
            9'h048: imem_rdata = 32'h00000013;
            9'h04C: imem_rdata = 32'h00000013;
            9'h050: imem_rdata = 32'h02019193; // SLLI x3, x3, 32
            9'h054: imem_rdata = 32'h00000013;
            9'h058: imem_rdata = 32'h00000013;
            9'h05C: imem_rdata = 32'h00000013;
            // SD x3, 8(x1)
            9'h060: imem_rdata = 32'h0030B423; // SD x3, 8(x1)
            9'h064: imem_rdata = 32'h00000013;
            9'h068: imem_rdata = 32'h00000013;
            9'h06C: imem_rdata = 32'h00000013;
            // FLD f1, 0(x1)
            9'h070: imem_rdata = 32'h0000B087; // FLD f1, 0(x1)
            9'h074: imem_rdata = 32'h00000013;
            9'h078: imem_rdata = 32'h00000013;
            9'h07C: imem_rdata = 32'h00000013;
            // FLD f2, 8(x1)
            9'h080: imem_rdata = 32'h0080B107; // FLD f2, 8(x1)
            9'h084: imem_rdata = 32'h00000013;
            9'h088: imem_rdata = 32'h00000013;
            9'h08C: imem_rdata = 32'h00000013;
            // FMUL.D f3, f1, f2 → f3 = 3.0 * 4.0 = 12.0
            9'h090: imem_rdata = 32'h122081D3; // FMUL.D f3, f1, f2
            9'h094: imem_rdata = 32'h00000013;
            9'h098: imem_rdata = 32'h00000013;
            9'h09C: imem_rdata = 32'h00000013;
            // FSD f3, 16(x1)
            9'h0A0: imem_rdata = 32'h0030B827; // FSD f3, 16(x1)
            9'h0A4: imem_rdata = 32'h00000013;
            9'h0A8: imem_rdata = 32'h00000013;
            9'h0AC: imem_rdata = 32'h00000013;
            // LD x2, 16(x1) → x2 = FMUL result
            9'h0B0: imem_rdata = 32'h0100B103; // LD x2, 16(x1)
            9'h0B4: imem_rdata = 32'h00000013;
            9'h0B8: imem_rdata = 32'h00000013;
            9'h0BC: imem_rdata = 32'h00000013;
            // ADDI x4, x0, 7
            9'h0C0: imem_rdata = 32'h00700213; // ADDI x4, x0, 7
            9'h0C4: imem_rdata = 32'h00000013;
            9'h0C8: imem_rdata = 32'h00000013;
            9'h0CC: imem_rdata = 32'h00000013;
            // FCVT.D.W f4, x4 → f4 = 7.0
            // FCVT.D.W: opcode=1010011, funct7=1101001, rs2=00000, rs1=x4, rm=000, rd=f4
            // = 1101001_00000_00100_000_00100_1010011 = 0xD2020253
            9'h0D0: imem_rdata = 32'hD2020253; // FCVT.D.W f4, x4
            9'h0D4: imem_rdata = 32'h00000013;
            9'h0D8: imem_rdata = 32'h00000013;
            9'h0DC: imem_rdata = 32'h00000013;
            // FSD f4, 24(x1)
            9'h0E0: imem_rdata = 32'h0040BC27; // FSD f4, 24(x1)
            9'h0E4: imem_rdata = 32'h00000013;
            9'h0E8: imem_rdata = 32'h00000013;
            9'h0EC: imem_rdata = 32'h00000013;
            // LD x3, 24(x1) → x3 = FCVT result
            9'h0F0: imem_rdata = 32'h0180B183; // LD x3, 24(x1)
            9'h0F4: imem_rdata = 32'h00000013;
            9'h0F8: imem_rdata = 32'h00000013;
            9'h0FC: imem_rdata = 32'h00000013;
            // Loop
            9'h100: imem_rdata = 32'h0000006F; // JAL x0, 0
            default: imem_rdata = 32'h00000013;
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x2 = 12.0 = 0x4028000000000000, x3 = 7.0 = 0x401C000000000000
    assign o_pass = dbg_r2 == 64'h4028000000000000
                 && dbg_r3 == 64'h401C000000000000;
}

#[test(test_fp_mul_cvt)]
module test_fp_mul_cvt {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_fp_mul_cvt_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(500);
        $display(r1, r2, r3, pass);
        $assert(pass, "FMUL.D/FCVT.D.W integration test failed");
        $display("FMUL.D/FCVT.D.W integration test passed");
        $finish();
    }
}
