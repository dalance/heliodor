// Context switch test: timer-driven preemptive multitasking with two U-mode processes
module test_smode_ctxswitch_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var iptw_addr : logic<64>     ;
    var iptw_req  : logic         ;
    var iptw_rdata: logic<64>     ;
    var _dbg_stall: logic<8>      ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : iptw_addr ,
        o_iptw_req     : iptw_req  ,
        i_iptw_rdata   : iptw_rdata,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
        o_dbg_stall    : _dbg_stall,
    );

    var code_mem: logic<32> [512];
    initial {
        $readmemh("test/hex/smode_ctxswitch_test.hex", code_mem);
    }

    var data_mem: logic<32> [8192];

    let imem_is_data : logic     = imem_addr[15:0] >= 16'h1000;
    let imem_byte_off: logic<16> = imem_addr[15:0] - 16'h1000;
    assign imem_rdata    = if imem_is_data ? data_mem[imem_byte_off[14:2]] : code_mem[imem_addr[10:2]];

    let iptw_is_data : logic     = iptw_addr[15:0] >= 16'h1000;
    let iptw_byte_off: logic<16> = iptw_addr[15:0] - 16'h1000;
    assign iptw_rdata    = if iptw_is_data ?
        {data_mem[{iptw_byte_off[14:3], 1'b1}], data_mem[{iptw_byte_off[14:3], 1'b0}]}
    :
        {code_mem[{iptw_addr[10:3], 1'b1}], code_mem[{iptw_addr[10:3], 1'b0}]}
    ;

    let is_data      : logic     = dmem_addr[31:16] == 16'd0 && dmem_addr[15:12] != 4'h0;
    let dmem_byte_off: logic<16> = dmem_addr[15:0] - 16'h1000;
    let data_dw_lo   : logic<13> = {dmem_byte_off[14:3], 1'b0};
    let data_dw_hi   : logic<13> = {dmem_byte_off[14:3], 1'b1};

    assign dmem_rdata = if is_data ?
        {data_mem[data_dw_hi], data_mem[data_dw_lo]}
    :
        {code_mem[{dmem_addr[10:3], 1'b1}], code_mem[{dmem_addr[10:3], 1'b0}]}
    ;

    always_ff (clk, rst) {
        if_reset {} else if dmem_wen && is_data {
            if dmem_wstrb[3:0] != 4'd0 {
                var lo                  : logic<32>;
                lo                   = data_mem[data_dw_lo];
                if dmem_wstrb[0] {
                    lo[7:0]              = dmem_wdata[7:0];
                }
                if dmem_wstrb[1] {
                    lo[15:8]             = dmem_wdata[15:8];
                }
                if dmem_wstrb[2] {
                    lo[23:16]            = dmem_wdata[23:16];
                }
                if dmem_wstrb[3] {
                    lo[31:24]            = dmem_wdata[31:24];
                }
                data_mem[data_dw_lo] = lo;
            }
            if dmem_wstrb[7:4] != 4'd0 {
                var hi                  : logic<32>;
                hi                   = data_mem[data_dw_hi];
                if dmem_wstrb[4] {
                    hi[7:0]              = dmem_wdata[39:32];
                }
                if dmem_wstrb[5] {
                    hi[15:8]             = dmem_wdata[47:40];
                }
                if dmem_wstrb[6] {
                    hi[23:16]            = dmem_wdata[55:48];
                }
                if dmem_wstrb[7] {
                    hi[31:24]            = dmem_wdata[63:56];
                }
                data_mem[data_dw_hi] = hi;
            }
        }
    }

    assign o_r1   = dbg_r1; // x1
    assign o_r2   = dbg_regs[9]; // x9 (debug marker)
    assign o_r3   = dbg_r3; // x3
    assign o_pass = dbg_r3 == 64'hAA;
}

#[test(test_smode_ctxswitch)]
module test_smode_ctxswitch {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_smode_ctxswitch_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (500000);
        $display  ("x1=%h x9=%h x3=%h pass=%b", r1, r2, r3, pass);
        $assert   (pass, "Context switch: expected x3=0xAA (both processes ran)");
        $display  ("Context switch test passed");
        $finish   ();
    }
}
