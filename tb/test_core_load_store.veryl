// Integration test for LOAD/STORE (SD + LD)
module test_core_load_store_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;

    inst dut: heliodor_top (
        clk                          ,
        rst                          ,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
    );

    // Simple data memory (8 doublewords)
    var dmem: logic<64> [8];

    always_comb {
        // Read: return stored value at word-aligned address
        dmem_rdata = dmem[dmem_addr[5:3]];
    }

    always_ff (clk, rst) {
        if_reset {
            dmem[0] = 64'd0;
            dmem[1] = 64'd0;
            dmem[2] = 64'd0;
            dmem[3] = 64'd0;
            dmem[4] = 64'd0;
            dmem[5] = 64'd0;
            dmem[6] = 64'd0;
            dmem[7] = 64'd0;
        } else if dmem_wen {
            dmem[dmem_addr[5:3]] = dmem_wdata;
        }
    }

    // Program: store a value, then load it back
    //   0x00: ADDI  x1, x0, 42     -> x1 = 42
    //   0x04: SD    x1, 0(x0)      -> mem[0] = 42
    //   0x08: NOP                   -> pipeline bubble
    //   0x0C: NOP                   -> pipeline bubble
    //   0x10: LD    x2, 0(x0)      -> x2 = mem[0] = 42
    //   0x14: NOP
    //   0x18: NOP
    //   0x1C: ADDI  x3, x2, 8      -> x3 = x2 + 8 = 50
    //   0x20+: NOP
    //
    // Encoding:
    //   ADDI x1, x0, 42:  0x02A00093
    //   SD   x1, 0(x0):   S-type, funct3=011, imm=0
    //     imm[11:5]=0000000, rs2=1, rs1=0, f3=011, imm[4:0]=00000, op=0100011
    //     = 0x00103023
    //   LD   x2, 0(x0):   I-type, funct3=011, imm=0
    //     imm=000000000000, rs1=0, f3=011, rd=2, op=0000011
    //     = 0x00003103
    //   ADDI x3, x2, 8:   0x00810193
    always_comb {
        case imem_addr[7:0] {
            8'h00:   imem_rdata = 32'h02A00093; // ADDI x1, x0, 42
            8'h04:   imem_rdata = 32'h00103023; // SD   x1, 0(x0)
            8'h08:   imem_rdata = 32'h00000013; // NOP
            8'h0C:   imem_rdata = 32'h00000013; // NOP
            8'h10:   imem_rdata = 32'h00003103; // LD   x2, 0(x0)
            8'h14:   imem_rdata = 32'h00000013; // NOP
            8'h18:   imem_rdata = 32'h00000013; // NOP
            8'h1C:   imem_rdata = 32'h00810193; // ADDI x3, x2, 8
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x1=42, x2=42, x3=50
    assign o_pass = dbg_r1 == 64'd42
                 && dbg_r2 == 64'd42
                 && dbg_r3 == 64'd50;
}

#[test(test_core_load_store)]
module test_core_load_store {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_core_load_store_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(50);
        $display(r1, r2, r3, pass);
        $assert(pass, "LOAD/STORE register values mismatch");
        $display("LOAD/STORE integration test passed");
        $finish();
    }
}
