// Integration test: Fibonacci(10) loaded from hex file.
// Exercises branches, arithmetic, and register operations through the full pipeline.
module test_fibonacci_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var _iptw_addr: logic<64>     ;
    var _iptw_req : logic         ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : _iptw_addr,
        o_iptw_req     : _iptw_req ,
        i_iptw_rdata   : 64'd0     ,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
    );

    // Instruction memory loaded from hex file
    var imem: logic<32> [4096];
    initial {
        $readmemh("test/hex/fibonacci.hex", imem);
    }
    assign imem_rdata = imem[imem_addr[13:2]];

    // Data memory (unused in this test but required by interface)
    var dmem: logic<64> [32];
    always_ff (clk, rst) {
        if_reset {
            for i: i32 in 0..32 {
                dmem[i] = 64'd0;
            }
        } else if dmem_wen {
            dmem[dmem_addr[7:3]] = dmem_wdata;
        }
    }
    assign dmem_rdata = dmem[dmem_addr[7:3]];

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;

    // After 10 iterations: x2 = fib(10) = 55, x3 = fib(11) = 89
    assign o_pass = dbg_r2 == 64'h37 && dbg_r3 == 64'h59;
}

#[test(test_fibonacci)]
module test_fibonacci {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_fibonacci_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (1000);
        $display  (r1, r2, r3, pass);
        $assert   (pass, "Fibonacci: x2=55(0x37) x3=89(0x59) failed");
        $display  ("Fibonacci test passed");
        $finish   ();
    }
}
