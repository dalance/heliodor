// Minimal reproduction of dcache→MMU comb chain stall issue.
// cache2_like: 1-set direct-mapped, 8-cycle fill, FILL/DONE states.
// mmu2_like: PTW reads addr 0x10 (tag 1), DONE reads addr 0x20 (tag 2, miss).
// After PTW fill completes (tag 1 cached), MMU enters DONE.
// DONE reads addr 0x20 which misses (different tag in same set).
// The miss should stall the pipeline until the second fill completes.

pub module cache2_like (
    clk    : input  clock,
    rst    : input  reset,
    i_ren  : input  logic,
    i_addr : input  logic<8>,
    o_stall: output logic,
    o_data : output logic<8>,
) {
    let tag: logic<4> = i_addr[7:4];
    var valid: logic;
    var c_tag: logic<4>;
    var data : logic<8>;

    enum State: logic<2> {
        IDLE = 2'd0,
        FILL = 2'd1,
        DONE = 2'd2,
    }
    var state: State;

    let hit : logic = valid && c_tag == tag;
    let miss: logic = i_ren && !hit && state == State::IDLE;
    var fill_count: logic<3>;
    var fill_tag  : logic<4>;

    always_ff (clk, rst) {
        if_reset {
            state = State::IDLE;
            valid = 1'b0;
            c_tag = 4'd0;
            data  = 8'd0;
            fill_count = 3'd0;
            fill_tag   = 4'd0;
        } else {
            case state {
                State::IDLE: {
                    if miss {
                        fill_tag   = tag;
                        fill_count = 3'd0;
                        state = State::FILL;
                    }
                }
                State::FILL: {
                    if fill_count == 3'd7 {
                        valid = 1'b1;
                        c_tag = fill_tag;
                        data  = 8'hAB;
                        state = State::DONE;
                    } else {
                        fill_count = fill_count + 3'd1;
                    }
                }
                State::DONE: {
                    state = State::IDLE;
                }
                default: {
                    state = State::IDLE;
                }
            }
        }
    }

    assign o_stall = (state == State::FILL) || miss || (state == State::DONE);
    assign o_data  = if hit ? data : 8'd0;
}

pub module mmu2_like (
    clk    : input  clock,
    rst    : input  reset,
    i_req  : input  logic,
    o_ren  : output logic,
    o_addr : output logic<8>,
    o_busy : output logic,
    o_valid: output logic,
    i_stall: input  logic,
) {
    enum State: logic<2> {
        IDLE = 2'd0,
        PTW  = 2'd1,
        DONE = 2'd2,
    }
    var state: State;

    always_ff (clk, rst) {
        if_reset {
            state = State::IDLE;
        } else {
            case state {
                State::IDLE: if i_req { state = State::PTW; }
                State::PTW:  if !i_stall { state = State::DONE; }
                State::DONE: if !i_stall { state = State::IDLE; }
                default: state = State::IDLE;
            }
        }
    }

    assign o_addr  = if state == State::PTW ? 8'h10
                   : if state == State::DONE ? 8'h20
                   : 8'h00;
    assign o_ren   = state == State::PTW || state == State::DONE;
    assign o_busy  = state == State::PTW;
    assign o_valid = state == State::DONE;
}

// Wrapper around mmu2_like (simulates dmem_mmu wrapping mmu)
// Adds one extra hierarchy level to the comb chain.
pub module mmu2_wrapper (
    clk    : input  clock,
    rst    : input  reset,
    i_req  : input  logic,
    o_ren  : output logic,
    o_addr : output logic<8>,
    o_busy : output logic,
    o_valid: output logic,
    i_stall: input  logic,
) {
    var inner_ren  : logic;
    var inner_addr : logic<8>;
    var inner_busy : logic;
    var inner_valid: logic;

    inst u_inner: mmu2_like (
        clk, rst,
        i_req  : i_req,
        o_ren  : inner_ren,
        o_addr : inner_addr,
        o_busy : inner_busy,
        o_valid: inner_valid,
        i_stall: i_stall,
    );

    // Pass through with combinational assigns (like dmem_mmu does)
    assign o_ren   = inner_ren;
    assign o_addr  = inner_addr;
    assign o_busy  = inner_busy || (inner_valid && i_stall);
    assign o_valid = inner_valid;
}

module test_comb_chain_harness (
    clk    : input  clock,
    rst    : input  reset,
    o_pass : output logic,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var cache_stall: logic;
    var cache_data : logic<8>;
    var mmu_ren    : logic;
    var mmu_addr   : logic<8>;
    var mmu_busy   : logic;
    var mmu_valid  : logic;

    inst u_cache: cache2_like (
        clk, rst,
        i_ren  : mmu_ren,
        i_addr : mmu_addr,
        o_stall: cache_stall,
        o_data : cache_data,
    );

    // Wrap mmu2_like in a parent (like dmem_mmu wraps mmu) for deeper hierarchy
    inst u_mmu_wrapper: mmu2_wrapper (
        clk, rst,
        i_req  : 1'b1,
        o_ren  : mmu_ren,
        o_addr : mmu_addr,
        o_busy : mmu_busy,
        o_valid: mmu_valid,
        i_stall: cache_stall,
    );

    let stall: logic = cache_stall || mmu_busy;

    var count: logic<8>;
    always_ff (clk, rst) {
        if_reset {
            count = 8'd0;
        } else if !stall {
            count = count + 8'd1;
        }
    }

    var captured: logic<8>;
    always_ff (clk, rst) {
        if_reset {
            captured = 8'd0;
        } else if mmu_valid && !cache_stall {
            captured = cache_data;
        }
    }

    var cycle: logic<8>;
    always_ff (clk, rst) {
        if_reset {
            cycle = 8'd0;
        } else {
            cycle = cycle + 8'd1;
            if cycle <: 8'd30 {
                $display("c%d ren=%b addr=%h stall=%b busy=%b valid=%b data=%h cnt=%d",
                    cycle, mmu_ren, mmu_addr, cache_stall, mmu_busy, mmu_valid,
                    cache_data, count);
            }
        }
    }

    assign o_r1 = {56'd0, captured};
    assign o_r2 = {56'd0, count};
    assign o_r3 = '0;
    assign o_pass = captured == 8'hAB;
}

#[test(test_comb_chain)]
module test_comb_chain {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_comb_chain_harness (
        clk    : clk ,
        rst    : rst ,
        o_pass : pass,
        o_r1   : r1  ,
        o_r2   : r2  ,
        o_r3   : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next(30);
        $display("captured=%h count=%d pass=%b", r1, r2, pass);
        $assert(pass, "comb_chain: should capture 0xAB from second fill");
        $finish();
    }
}
