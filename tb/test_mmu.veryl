// Sv39 MMU unit test: page table walk through dmem_mmu
module test_mmu_harness (
    clk    : input  clock,
    rst    : input  reset,
    o_pass : output logic,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    import csr_pkg::*;

    // DUT signals
    var vaddr     : logic<64>;
    var wdata     : logic<64>;
    var wen       : logic;
    var ren       : logic;
    var wstrb     : logic<8>;
    var rdata     : logic<64>;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var satp_val  : logic<64>;
    var priv_val  : PrivLevel;
    var busy      : logic;
    var fault     : logic;
    var fault_st  : logic;

    inst dut: dmem_mmu (
        clk, rst,
        i_vaddr      : vaddr,
        i_wdata      : wdata,
        i_wen        : wen,
        i_ren        : ren,
        i_wstrb      : wstrb,
        o_rdata      : rdata,
        o_dmem_addr  : dmem_addr,
        o_dmem_wdata : dmem_wdata,
        i_dmem_rdata : dmem_rdata,
        o_dmem_wen   : dmem_wen,
        o_dmem_ren   : dmem_ren,
        o_dmem_wstrb : dmem_wstrb,
        i_satp       : satp_val,
        i_priv       : priv_val,
        i_sum        : 1'b1,
        i_mxr        : 1'b0,
        o_busy       : busy,
        o_fault      : fault,
        o_fault_store: fault_st,
    );

    // Simple memory (256 doublewords = 2KB)
    var mem: logic<64> [256];

    // Comb read
    assign dmem_rdata = mem[dmem_addr[10:3]];

    // Test state machine
    var tc: logic<8>;
    var stored_rdata: logic<64>;
    var bare_rdata  : logic<64>;
    var sv39_started: logic;
    var sv39_was_busy: logic;

    always_ff (clk, rst) {
        if_reset {
            tc = 8'd0;
            vaddr = '0;
            wdata = '0;
            wen   = 1'b0;
            ren   = 1'b0;
            wstrb = '0;
            satp_val = '0;
            priv_val = PrivLevel::MACHINE;
            stored_rdata = '0;
            bare_rdata   = '0;
            sv39_started  = 1'b0;
            sv39_was_busy = 1'b0;

            // Initialize page table in memory
            // Root page table at physical page 0 (byte address 0x0), satp.PPN=0
            // Level-2 PTE at root[VPN2=0] = root[0] = mem[0]
            //   Leaf gigapage: V=1, R=1, W=1, X=0, U=1, A=1, D=1, PPN=0
            //   PTE = {PPN=0, RSW=0, D=1, A=1, G=0, U=1, X=0, W=1, R=1, V=1}
            //       = 0x00000000_000000DF
            mem[0] = 64'h00000000_000000DF;

            // Data at physical address 0x100 (word index 32): pre-loaded value
            mem[32]  = 64'hDEAD_BEEF_CAFE_BABE;

        } else {
            // Default: no memory access
            wen   = 1'b0;
            ren   = 1'b0;

            if !busy {
                tc = tc + 8'd1;
            }

            case tc {
                // Phase 1: Bare mode test (M-mode, satp=0)
                8'd1: {
                    vaddr = 64'h0000_0000_0000_0100;
                    ren   = 1'b1;
                }
                8'd2: {
                    bare_rdata = rdata;
                }

                // Phase 2: Enable Sv39 (S-mode, satp with MODE=8)
                8'd4: {
                    satp_val = {4'd8, 16'd0, 44'd0};
                    priv_val = PrivLevel::SUPERVISOR;
                }

                // Phase 3: Read same address in Sv39 mode
                8'd6: {
                    vaddr = 64'h0000_0000_0000_0100;
                    ren   = 1'b1;
                    sv39_started = 1'b1;
                }

                default: {}
            }

            // Capture rdata when PTW completes (busy falls from 1→0)
            if sv39_started && sv39_was_busy && !busy {
                stored_rdata = rdata;
            }
            sv39_was_busy = busy;

            // Memory write
            if dmem_wen {
                mem[dmem_addr[10:3]] = dmem_wdata;
            }
        }
    }

    assign o_r1 = bare_rdata;
    assign o_r2 = stored_rdata;
    assign o_r3 = 64'd0;
    assign o_pass = bare_rdata == 64'hDEAD_BEEF_CAFE_BABE
                 && stored_rdata == 64'hDEAD_BEEF_CAFE_BABE;
}

#[test(test_mmu)]
module test_mmu {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_mmu_harness (
        clk: clk, rst: rst,
        o_pass: pass, o_r1: r1, o_r2: r2, o_r3: r3,
    );

    initial {
        rst.assert(clk);
        for _i: i32 in 0..50 {
            clk.next(1);
        }
        $display(r1, r2, r3, pass);
        $assert(pass, "MMU test failed");
        $display("MMU Sv39 page table walk test passed");
        $finish();
    }
}
