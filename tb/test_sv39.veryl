// Sv39 MMU integration test: identity-mapped 1GB gigapage, M→S mode switch.
// M-mode sets up page table at 0x1000, enables Sv39, MRETs to S-mode.
// S-mode writes "SV39 OK\n" via UART through virtual addresses.
module test_sv39_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var iptw_addr : logic<64>     ;
    var iptw_req  : logic         ;
    var iptw_rdata: logic<64>     ;
    var uart_tx   : logic         ;
    var uart_data : logic<8>      ;
    var dbg_stall : logic<8>      ;

    inst dut: heliodor_top (
        clk                     ,
        rst                     ,
        o_imem_addr : imem_addr ,
        i_imem_rdata: imem_rdata,
        o_imem_ren  : imem_ren  ,
        o_iptw_addr : iptw_addr ,
        o_iptw_req  : iptw_req  ,
        i_iptw_rdata: iptw_rdata,
        o_dmem_addr : dmem_addr ,
        o_dmem_wdata: dmem_wdata,
        i_dmem_rdata: dmem_rdata,
        o_dmem_wen  : dmem_wen  ,
        o_dmem_ren  : dmem_ren  ,
        o_dmem_wstrb: dmem_wstrb,
        o_dbg_regs  : dbg_regs  ,
        o_dbg_pc    : dbg_pc    ,
        o_dbg_pass  : dbg_pass  ,
        o_dbg_r1    : dbg_r1    ,
        o_dbg_r2    : dbg_r2    ,
        o_dbg_r3    : dbg_r3    ,
        i_ext_irq   : 32'd0     ,
        o_uart_tx   : uart_tx   ,
        o_uart_data : uart_data ,
        o_dbg_stall : dbg_stall ,
    );

    // Code memory (read-only, 256 words = 1KB)
    var code_mem: logic<32> [256];
    initial {
        $readmemh("test/hex/sv39_test.hex", code_mem);
    }

    // Data memory (read-write, 2048 words = 8KB, mapped to 0x1000-0x2FFF)
    // Used for the Sv39 page table built at runtime.
    var data_mem: logic<32> [2048];

    // Stack memory (read-write, 256 words, mapped to 0x7C00-0x83FF)
    var stk_mem: logic<32> [256];

    // Instruction read (from code memory, addr < 0x400)
    assign imem_rdata = code_mem[imem_addr[9:2]];

    // Instruction PTW read (64-bit, same memory decode as dmem)
    let iptw_is_data: logic = iptw_addr[15:12] == 4'h1 || iptw_addr[15:12] == 4'h2;
    assign iptw_rdata   = if iptw_is_data ?
        {data_mem[{iptw_addr[12:3], 1'b1}], data_mem[{iptw_addr[12:3], 1'b0}]}
    :
        {code_mem[{iptw_addr[9:3], 1'b1}], code_mem[{iptw_addr[9:3], 1'b0}]}
    ;

    // Address decode for data memory regions
    let is_data: logic = dmem_addr[15:12] == 4'h1 || dmem_addr[15:12] == 4'h2;
    let is_stk : logic = dmem_addr[15:10] == 6'b011111 || dmem_addr[15:10] == 6'b100000;

    // Data memory word indices
    let data_dw_lo: logic<11> = {dmem_addr[12:3], 1'b0};
    let data_dw_hi: logic<11> = {dmem_addr[12:3], 1'b1};
    let stk_dw_lo : logic<8>  = {dmem_addr[9:3], 1'b0};
    let stk_dw_hi : logic<8>  = {dmem_addr[9:3], 1'b1};
    let code_dw_lo: logic<8>  = {dmem_addr[9:3], 1'b0};
    let code_dw_hi: logic<8>  = {dmem_addr[9:3], 1'b1};

    // Data read (64-bit)
    assign dmem_rdata = if is_data ?
        {data_mem[data_dw_hi], data_mem[data_dw_lo]}
    : if is_stk ?
        {stk_mem[stk_dw_hi], stk_mem[stk_dw_lo]}
    :
        {code_mem[code_dw_hi], code_mem[code_dw_lo]}
    ;

    // Data write
    always_ff (clk, rst) {
        if_reset {} else if dmem_wen && dmem_addr[31:16] == 16'd0 {
            if is_data {
                if dmem_wstrb[3:0] != 4'd0 {
                    var lo                  : logic<32>;
                    lo                   = data_mem[data_dw_lo];
                    if dmem_wstrb[0] {
                        lo[7:0]              = dmem_wdata[7:0];
                    }
                    if dmem_wstrb[1] {
                        lo[15:8]             = dmem_wdata[15:8];
                    }
                    if dmem_wstrb[2] {
                        lo[23:16]            = dmem_wdata[23:16];
                    }
                    if dmem_wstrb[3] {
                        lo[31:24]            = dmem_wdata[31:24];
                    }
                    data_mem[data_dw_lo] = lo;
                }
                if dmem_wstrb[7:4] != 4'd0 {
                    var hi                  : logic<32>;
                    hi                   = data_mem[data_dw_hi];
                    if dmem_wstrb[4] {
                        hi[7:0]              = dmem_wdata[39:32];
                    }
                    if dmem_wstrb[5] {
                        hi[15:8]             = dmem_wdata[47:40];
                    }
                    if dmem_wstrb[6] {
                        hi[23:16]            = dmem_wdata[55:48];
                    }
                    if dmem_wstrb[7] {
                        hi[31:24]            = dmem_wdata[63:56];
                    }
                    data_mem[data_dw_hi] = hi;
                }
            } else if is_stk {
                if dmem_wstrb[3:0] != 4'd0 {
                    var lo                : logic<32>;
                    lo                 = stk_mem[stk_dw_lo];
                    if dmem_wstrb[0] {
                        lo[7:0]            = dmem_wdata[7:0];
                    }
                    if dmem_wstrb[1] {
                        lo[15:8]           = dmem_wdata[15:8];
                    }
                    if dmem_wstrb[2] {
                        lo[23:16]          = dmem_wdata[23:16];
                    }
                    if dmem_wstrb[3] {
                        lo[31:24]          = dmem_wdata[31:24];
                    }
                    stk_mem[stk_dw_lo] = lo;
                }
                if dmem_wstrb[7:4] != 4'd0 {
                    var hi                : logic<32>;
                    hi                 = stk_mem[stk_dw_hi];
                    if dmem_wstrb[4] {
                        hi[7:0]            = dmem_wdata[39:32];
                    }
                    if dmem_wstrb[5] {
                        hi[15:8]           = dmem_wdata[47:40];
                    }
                    if dmem_wstrb[6] {
                        hi[23:16]          = dmem_wdata[55:48];
                    }
                    if dmem_wstrb[7] {
                        hi[31:24]          = dmem_wdata[63:56];
                    }
                    stk_mem[stk_dw_hi] = hi;
                }
            }
        }
    }

    // Capture UART output
    var tx_buf  : logic<8> [16];
    var tx_count: logic<5>     ;
    always_ff (clk, rst) {
        if_reset {
            for i: i32 in 0..16 {
                tx_buf[i] = 8'd0;
            }
            tx_count  = 5'd0;
        } else if uart_tx && (tx_count <: 5'd16) {
            tx_buf[tx_count] = uart_data;
            tx_count         = tx_count + 5'd1;
        }
    }

    // Debug trace
    var cycle: logic<16>;
    always_ff (clk, rst) {
        if_reset {
            cycle = 16'd0;
        } else {
            cycle = cycle + 16'd1;
            if cycle >: 16'd2650 && cycle <: 16'd2700 {
                $display("c%d pc=%h da=%h ren=%b wen=%b x3=%h stall=%h", cycle, dbg_pc, dmem_addr, dmem_ren, dmem_wen, dbg_regs[3], dbg_stall);
            }
        }
    }

    // x3 = 0xAA (pass) or 0xBB (fail)
    assign o_r1 = dbg_regs[3];
    assign o_r2 = dbg_regs[11];
    assign o_r3 = dbg_regs[12];

    // Pass: x3 = 0xAA (MMU read/write through virtual addresses worked)
    assign o_pass = dbg_regs[3] == 64'hAA;
}

#[test(test_sv39)]
module test_sv39 {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_sv39_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (100000);
        $display  ("x3=%h a1=%h a2=%h pass=%b", r1, r2, r3, pass);
        $assert   (pass, "Sv39: expected x3=0xAA (MMU read/write passed)");
        $display  ("Sv39 MMU test passed");
        $finish   ();
    }
}
