// Bare-metal Hello World test: CPU writes "Hello, World!\n" to UART via MMIO.
// Validates memory-mapped I/O, SB (byte store), and sequential program execution
// from a hex-loaded program. This is a key Phase 8 milestone.
module test_hello_world_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var uart_tx   : logic;
    var uart_data : logic<8>;

    inst dut: heliodor_top (
        clk, rst,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
        o_uart_tx    : uart_tx       ,
        o_uart_data  : uart_data     ,
    );

    // Instruction memory loaded from hex
    var imem: logic<32> [4096];
    initial {
        $readmemh("test/hex/hello_world.hex", imem);
    }
    assign imem_rdata = imem[imem_addr[13:2]];

    // Data memory (unused but required)
    var dmem: logic<64> [32];
    always_ff (clk, rst) {
        if_reset { for i: i32 in 0..32 { dmem[i] = 64'd0; } }
        else if dmem_wen { dmem[dmem_addr[7:3]] = dmem_wdata; }
    }
    assign dmem_rdata = dmem[dmem_addr[7:3]];

    // Capture UART TX bytes into a buffer
    // "Hello, World!\n" = 14 bytes
    var tx_buf: logic<8> [16];
    var tx_count: logic<5>;
    always_ff (clk, rst) {
        if_reset {
            for i: i32 in 0..16 { tx_buf[i] = 8'd0; }
            tx_count = 5'd0;
        } else if uart_tx && (tx_count <: 5'd16) {
            tx_buf[tx_count] = uart_data;
            tx_count = tx_count + 5'd1;
        }
    }

    assign o_r1 = {59'd0, tx_count};
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;

    // Verify "Hello, World!\n"
    assign o_pass = tx_count == 5'd14
                 && tx_buf[0]  == 8'h48   // H
                 && tx_buf[1]  == 8'h65   // e
                 && tx_buf[2]  == 8'h6C   // l
                 && tx_buf[3]  == 8'h6C   // l
                 && tx_buf[4]  == 8'h6F   // o
                 && tx_buf[5]  == 8'h2C   // ,
                 && tx_buf[6]  == 8'h20   // SP
                 && tx_buf[7]  == 8'h57   // W
                 && tx_buf[8]  == 8'h6F   // o
                 && tx_buf[9]  == 8'h72   // r
                 && tx_buf[10] == 8'h6C   // l
                 && tx_buf[11] == 8'h64   // d
                 && tx_buf[12] == 8'h21   // !
                 && tx_buf[13] == 8'h0A;  // \n
}

#[test(test_hello_world)]
module test_hello_world {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_hello_world_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(2000);
        $display(r1, r2, r3, pass);
        $assert(pass, "Hello World: expected 14 UART bytes 'Hello, World!\\n'");
        $display("Hello, World! test passed");
        $finish();
    }
}
