// Integration test for RV64M multiply/divide instructions
module test_core_mul_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var _iptw_addr: logic<64>     ;
    var _iptw_req : logic         ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : _iptw_addr,
        o_iptw_req     : _iptw_req ,
        i_iptw_rdata   : 64'd0     ,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
    );

    assign dmem_rdata = 64'd0;

    // Program: test MUL and DIVU through the pipeline
    //   0x00: ADDI  x1, x0, 7      -> x1 = 7
    //   0x04: ADDI  x2, x0, 6      -> x2 = 6
    //   0x08: NOP                   -> bubble for forwarding
    //   0x0C: NOP
    //   0x10: MUL   x3, x1, x2     -> x3 = 7 * 6 = 42
    //   0x14: NOP
    //   0x18: NOP
    //   0x1C: DIVU  x4, x3, x1     -> x4 = 42 / 7 = 6
    //   0x20+: NOP
    //
    // Encoding:
    //   ADDI x1, x0, 7:   0x00700093
    //   ADDI x2, x0, 6:   0x00600113
    //   MUL  x3, x1, x2:  R-type, funct7=0000001, rs2=2, rs1=1, funct3=000, rd=3, op=0110011
    //     = 0x022081B3
    //   DIVU x4, x3, x1:  R-type, funct7=0000001, rs2=1, rs1=3, funct3=101, rd=4, op=0110011
    //     = 0x0211D233
    always_comb {
        case imem_addr[7:0] {
            8'h00  : imem_rdata = 32'h00700093; // ADDI x1, x0, 7
            8'h04  : imem_rdata = 32'h00600113; // ADDI x2, x0, 6
            8'h08  : imem_rdata = 32'h00000013; // NOP
            8'h0C  : imem_rdata = 32'h00000013; // NOP
            8'h10  : imem_rdata = 32'h022081B3; // MUL  x3, x1, x2
            8'h14  : imem_rdata = 32'h00000013; // NOP
            8'h18  : imem_rdata = 32'h00000013; // NOP
            8'h1C  : imem_rdata = 32'h0211D233; // DIVU x4, x3, x1
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x1=7, x2=6, x3=42 (7*6)
    // dbg_r1=regs[1]=7, dbg_r2=regs[2]=6, dbg_r3=regs[3]=42
    assign o_pass = dbg_r1 == 64'd7 && dbg_r2 == 64'd6 && dbg_r3 == 64'd42;
}

#[test(test_core_mul)]
module test_core_mul {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_core_mul_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (45);
        $display  (r1, r2, r3, pass);
        $assert   (pass, "MUL/DIV register values mismatch");
        $display  ("MUL/DIV integration test passed");
        $finish   ();
    }
}
