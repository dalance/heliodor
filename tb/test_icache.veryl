// I-Cache unit test (read-only cache)
module test_icache_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
) {
    var addr     : logic<64>;
    var ren      : logic    ;
    var rdata    : logic<64>;
    var stall    : logic    ;
    var mem_addr : logic<64>;
    var mem_rdata: logic<64>;
    var mem_ren  : logic    ;

    inst dut: icache (
        clk                   ,
        rst                   ,
        i_addr     : addr     ,
        i_ren      : ren      ,
        o_rdata    : rdata    ,
        o_stall    : stall    ,
        o_mem_addr : mem_addr ,
        i_mem_rdata: mem_rdata,
        o_mem_ren  : mem_ren  ,
    );

    var mem      : logic<64> [256];
    assign mem_rdata = mem[mem_addr[10:3]];

    var tc    : logic<8> ;
    var r1_val: logic<64>;
    var r2_val: logic<64>;

    always_ff (clk, rst) {
        if_reset {
            tc     = 8'd0;
            addr   = '0;
            ren    = 1'b0;
            r1_val = '0;
            r2_val = '0;

            for i: i32 in 0..256 {
                if i == 0 {
                    mem[i] = 64'h0000_0000_0000_AAAA;
                } else if i == 1 {
                    mem[i] = 64'h0000_0000_0000_BBBB;
                } else {
                    mem[i] = 64'd0;
                }
            }
        } else {
            ren = 1'b0;

            // Hold ren during stall (fill in progress)
            if stall {
                ren = 1'b1;
            }

            if !stall {
                tc = tc + 8'd1;
            }

            case tc {
                // Phase 1: Read addr 0x000 (miss -> fill -> done)
                8'd1: {
                    addr = 64'h0;
                    ren  = 1'b1;
                }
                // tc=2: DONE->IDLE transition. tc=3: re-read (hit)
                8'd3: {
                    addr   = 64'h0;
                    ren    = 1'b1;
                }
                8'd4: {
                    r1_val = rdata;
                }

                // Phase 2: Read addr 0x008 (same line, hit)
                8'd6: {
                    addr   = 64'h0000_0000_0000_0008;
                    ren    = 1'b1;
                }
                8'd7: {
                    r2_val = rdata;
                }

                default: {}
            }
        }
    }

    assign o_r1   = r1_val;
    assign o_r2   = r2_val;
    assign o_pass = r1_val == 64'h0000_0000_0000_AAAA && r2_val == 64'h0000_0000_0000_BBBB;
}

#[test(test_icache)]
module test_icache {
    inst clk : $tb::clock_gen;
    inst rst : $tb::reset_gen;
    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    inst harness: test_icache_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
    );
    initial {
        rst.assert(clk);
        clk.next  (50);
        $display  (r1, r2, pass);
        $assert   (pass, "I-Cache test failed");
        $display  ("I-Cache test passed");
        $finish   ();
    }
}
