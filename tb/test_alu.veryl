// ALU unit test harness
module test_alu_harness (
    clk    : input  clock   ,
    rst    : input  reset   ,
    o_pass : output logic    ,
    o_done : output logic    ,
    o_tc   : output logic<8> ,
) {
    import alu_pkg::AluOp;

    // Test case counter
    var tc: logic<8>;

    always_ff {
        if_reset {
            tc = 8'd0;
        } else {
            tc = tc + 8'd1;
        }
    }

    assign o_tc = tc;

    // ALU signals
    var op : AluOp;
    var a  : logic<64>;
    var b  : logic<64>;
    var out: logic<64>;
    var exp: logic<64>;

    inst dut: alu (
        i_op : op ,
        i_a  : a  ,
        i_b  : b  ,
        o_out: out,
    );

    // Test vector ROM
    always_comb {
        op  = AluOp::ADD;
        a   = 64'd0;
        b   = 64'd0;
        exp = 64'd0;
        case tc {
            8'd1: { op = AluOp::ADD;  a = 64'd10;  b = 64'd20;  exp = 64'd30; }
            8'd2: { op = AluOp::SUB;  a = 64'd50;  b = 64'd30;  exp = 64'd20; }
            8'd3: { op = AluOp::AND;  a = 64'hFF00; b = 64'hF0F0; exp = 64'hF000; }
            8'd4: { op = AluOp::OR;   a = 64'hFF00; b = 64'h00FF; exp = 64'hFFFF; }
            8'd5: { op = AluOp::XOR;  a = 64'hFF00; b = 64'hF0F0; exp = 64'h0FF0; }
            8'd6: { op = AluOp::SLL;  a = 64'd1;    b = 64'd4;    exp = 64'd16; }
            8'd7: { op = AluOp::SRL;  a = 64'd128;  b = 64'd3;    exp = 64'd16; }
            8'd8: { op = AluOp::SRA;  a = 64'hFFFFFFFF_FFFFFFF0; b = 64'd2; exp = 64'hFFFFFFFF_FFFFFFFC; }
            8'd9: { op = AluOp::SLT;  a = 64'hFFFFFFFF_FFFFFFFF; b = 64'd1; exp = 64'd1; }
            8'd10: { op = AluOp::SLT; a = 64'd1; b = 64'hFFFFFFFF_FFFFFFFF; exp = 64'd0; }
            8'd11: { op = AluOp::SLTU; a = 64'd1; b = 64'hFFFFFFFF_FFFFFFFF; exp = 64'd1; }
            8'd12: { op = AluOp::ADDW; a = 64'h00000000_7FFFFFFF; b = 64'd1; exp = 64'hFFFFFFFF_80000000; }
            8'd13: { op = AluOp::SUBW; a = 64'd0; b = 64'd1; exp = 64'hFFFFFFFF_FFFFFFFF; }
            8'd14: { op = AluOp::SLLW; a = 64'd1; b = 64'd31; exp = 64'hFFFFFFFF_80000000; }
            8'd15: { op = AluOp::SRLW; a = 64'h00000000_80000000; b = 64'd1; exp = 64'h00000000_40000000; }
            8'd16: { op = AluOp::SRAW; a = 64'h00000000_80000000; b = 64'd1; exp = 64'hFFFFFFFF_C0000000; }
            // M extension
            8'd17: { op = AluOp::MUL;  a = 64'd7;  b = 64'd3;  exp = 64'd21; }
            8'd18: { op = AluOp::DIVU; a = 64'd100; b = 64'd7;  exp = 64'd14; }
            8'd19: { op = AluOp::REMU; a = 64'd100; b = 64'd7;  exp = 64'd2; }
            8'd20: { op = AluOp::MULW; a = 64'd1000; b = 64'd1000; exp = 64'd1000000; }
            // MULHU: upper 64 bits of unsigned 64x64 multiply
            // 0x8000_0000_0000_0000 * 2 = 0x1_0000_0000_0000_0000 → upper = 1
            8'd21: { op = AluOp::MULHU; a = 64'h80000000_00000000; b = 64'd2; exp = 64'd1; }
            // MULH: upper 64 bits of signed 64x64 multiply
            // (-1) * (-1) = 1 → upper = 0
            8'd22: { op = AluOp::MULH; a = 64'hFFFFFFFF_FFFFFFFF; b = 64'hFFFFFFFF_FFFFFFFF; exp = 64'd0; }
            // MULH: (-1) * 2 = -2 → upper = -1 (0xFFFF...FFFF)
            8'd23: { op = AluOp::MULH; a = 64'hFFFFFFFF_FFFFFFFF; b = 64'd2; exp = 64'hFFFFFFFF_FFFFFFFF; }
            // MULHSU: signed * unsigned: (-1) * 1 → upper = -1
            8'd24: { op = AluOp::MULHSU; a = 64'hFFFFFFFF_FFFFFFFF; b = 64'd1; exp = 64'hFFFFFFFF_FFFFFFFF; }
            // MULHU: small values → upper = 0
            8'd25: { op = AluOp::MULHU; a = 64'd100; b = 64'd200; exp = 64'd0; }
            default: {}
        }
    }

    // Check result
    assign o_pass = out == exp;
    assign o_done = tc >: 8'd25;
}

// Native testbench
#[test(test_alu)]
module test_alu {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var done: logic;
    var tc  : logic<8>;

    inst harness: test_alu_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_done: done,
        o_tc  : tc  ,
    );

    initial {
        rst.assert(clk);
        for _i: i32 in 0..26 {
            clk.next(1);
        }
        $assert(pass, "ALU test failed");
        $display("ALU test passed");
        $finish();
    }
}
