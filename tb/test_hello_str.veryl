// Integration test: bare-metal C program with string constants, UART output.
// Verifies puts (LBU→BNEZ loop), fib, put_dec (division), stack operations.
// Expected UART output: "Hello from C!\nfib(10)=55\nfib(20)=6765\n"
module test_hello_str_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var uart_tx   : logic;
    var uart_data : logic<8>;

    inst dut: heliodor_top (
        clk, rst,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
        o_uart_tx    : uart_tx       ,
        o_uart_data  : uart_data     ,
    );

    // Code + .rodata memory (read-only, 256 words = 1KB)
    var code_mem: logic<32> [256];
    initial {
        $readmemh("test/hex/hello_str.hex", code_mem);
    }

    // Stack memory (read-write, 256 words = 1KB, mapped to 0x7C00-0x83FF)
    // sp starts at 0x8000, stack grows downward.
    var stk_mem: logic<32> [256];

    // Address decoding
    let is_stk: logic = dmem_addr[15:10] == 6'b011111  // 0x7C00-0x7FFF
                     || dmem_addr[15:10] == 6'b100000;  // 0x8000-0x83FF
    // Stack word index: offset from 0x7C00, word-aligned
    let stk_word: logic<8> = dmem_addr[9:2];

    // Instruction read (from code memory)
    assign imem_rdata = code_mem[imem_addr[9:2]];

    // Data read (64-bit)
    let code_dw_lo: logic<8> = {dmem_addr[9:3], 1'b0};
    let code_dw_hi: logic<8> = {dmem_addr[9:3], 1'b1};
    let stk_dw_lo : logic<8> = {dmem_addr[9:3], 1'b0};
    let stk_dw_hi : logic<8> = {dmem_addr[9:3], 1'b1};

    assign dmem_rdata = if is_stk ?
        {stk_mem[stk_dw_hi], stk_mem[stk_dw_lo]}
    :   {code_mem[code_dw_hi], code_mem[code_dw_lo]};

    // Stack write (word-level with byte strobe)
    always_ff (clk, rst) {
        if_reset {
        } else if dmem_wen && is_stk {
            if dmem_wstrb[3:0] != 4'd0 {
                var lo: logic<32>;
                lo = stk_mem[stk_dw_lo];
                if dmem_wstrb[0] { lo[7:0]   = dmem_wdata[7:0];   }
                if dmem_wstrb[1] { lo[15:8]  = dmem_wdata[15:8];  }
                if dmem_wstrb[2] { lo[23:16] = dmem_wdata[23:16]; }
                if dmem_wstrb[3] { lo[31:24] = dmem_wdata[31:24]; }
                stk_mem[stk_dw_lo] = lo;
            }
            if dmem_wstrb[7:4] != 4'd0 {
                var hi: logic<32>;
                hi = stk_mem[stk_dw_hi];
                if dmem_wstrb[4] { hi[7:0]   = dmem_wdata[39:32]; }
                if dmem_wstrb[5] { hi[15:8]  = dmem_wdata[47:40]; }
                if dmem_wstrb[6] { hi[23:16] = dmem_wdata[55:48]; }
                if dmem_wstrb[7] { hi[31:24] = dmem_wdata[63:56]; }
                stk_mem[stk_dw_hi] = hi;
            }
        }
    }

    // Capture UART output
    var tx_buf: logic<8> [64];
    var tx_count: logic<7>;
    always_ff (clk, rst) {
        if_reset {
            for i: i32 in 0..64 { tx_buf[i] = 8'd0; }
            tx_count = 7'd0;
        } else if uart_tx && (tx_count <: 7'd64) {
            tx_buf[tx_count] = uart_data;
            tx_count = tx_count + 7'd1;
        }
    }

    // Debug outputs
    assign o_r1 = {57'd0, tx_count};
    assign o_r2 = {tx_buf[4], tx_buf[3], tx_buf[2], tx_buf[1], tx_buf[0],
                   24'd0};
    assign o_r3 = dbg_pc;

    // Pass: check first 5 UART chars are "Hello" and total is 38 chars
    assign o_pass = tx_count == 7'd38
                 && tx_buf[0] == 8'h48  // 'H'
                 && tx_buf[1] == 8'h65  // 'e'
                 && tx_buf[2] == 8'h6C  // 'l'
                 && tx_buf[3] == 8'h6C  // 'l'
                 && tx_buf[4] == 8'h6F  // 'o'
                 ;
}

#[test(test_hello_str)]
module test_hello_str {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_hello_str_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(200000);
        $display("tx_count=%d first_bytes=%h pc=%h pass=%b", r1, r2, r3, pass);
        $assert(pass, "hello_str: expected 38 UART chars starting with 'Hello'");
        $display("hello_str test passed");
        $finish();
    }
}
