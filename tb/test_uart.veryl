// UART output test: write 'H', 'i' to UART at 0x10000000
// Verify UART TX output and LSR (always-ready) read
module test_uart_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;
    var uart_tx   : logic;
    var uart_data : logic<8>;
    var _dbg_stall: logic<8>;

    inst dut: heliodor_top (
        clk, rst,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
        o_uart_tx    : uart_tx       ,
        o_uart_data  : uart_data     ,
        o_dbg_stall  : _dbg_stall    ,
    );

    // Simple data memory
    var mem: logic<64> [32];
    always_ff (clk, rst) {
        if_reset { for i: i32 in 0..32 { mem[i] = 64'd0; } }
        else if dmem_wen { mem[dmem_addr[7:3]] = dmem_wdata; }
    }
    assign dmem_rdata = mem[dmem_addr[7:3]];

    // Capture UART TX bytes
    var tx_byte0: logic<8>;
    var tx_byte1: logic<8>;
    var tx_count: logic<4>;
    always_ff (clk, rst) {
        if_reset {
            tx_byte0 = 8'd0;
            tx_byte1 = 8'd0;
            tx_count = 4'd0;
        } else if uart_tx {
            if tx_count == 4'd0 { tx_byte0 = uart_data; }
            else if tx_count == 4'd1 { tx_byte1 = uart_data; }
            tx_count = tx_count + 4'd1;
        }
    }

    // Test program:
    //   x1 = 0x10000000 (UART base)
    //   Store 'H' (0x48) to UART THR
    //   Read LSR → x2 (should have bit 5 set = 0x60)
    //   Store 'i' (0x69) to UART THR
    always_comb {
        case imem_addr[7:0] {
            // LUI x1, 0x10000 → x1 = 0x10000000
            8'h00: imem_rdata = 32'h100000B7; // LUI x1, 0x10000
            8'h04: imem_rdata = 32'h00000013;
            8'h08: imem_rdata = 32'h00000013;
            8'h0C: imem_rdata = 32'h00000013;
            // SB x2='H', 0(x1) → write 'H' to UART THR
            // First: ADDI x2, x0, 0x48
            8'h10: imem_rdata = 32'h04800113; // ADDI x2, x0, 0x48 ('H')
            8'h14: imem_rdata = 32'h00000013;
            8'h18: imem_rdata = 32'h00000013;
            8'h1C: imem_rdata = 32'h00000013;
            // SB x2, 0(x1) → byte store to UART
            8'h20: imem_rdata = 32'h00208023; // SB x2, 0(x1)
            8'h24: imem_rdata = 32'h00000013;
            8'h28: imem_rdata = 32'h00000013;
            8'h2C: imem_rdata = 32'h00000013;
            // LBU x3, 5(x1) → read UART LSR
            8'h30: imem_rdata = 32'h0050C183; // LBU x3, 5(x1)
            8'h34: imem_rdata = 32'h00000013;
            8'h38: imem_rdata = 32'h00000013;
            8'h3C: imem_rdata = 32'h00000013;
            // ADDI x4, x0, 0x69 ('i')
            8'h40: imem_rdata = 32'h06900213; // ADDI x4, x0, 0x69
            8'h44: imem_rdata = 32'h00000013;
            8'h48: imem_rdata = 32'h00000013;
            8'h4C: imem_rdata = 32'h00000013;
            // SB x4, 0(x1) → write 'i' to UART
            8'h50: imem_rdata = 32'h00408023; // SB x4, 0(x1)
            8'h54: imem_rdata = 32'h00000013;
            8'h58: imem_rdata = 32'h00000013;
            8'h5C: imem_rdata = 32'h00000013;
            // Loop
            8'h60: imem_rdata = 32'h0000006F;
            default: imem_rdata = 32'h00000013;
        }
    }

    assign o_r1 = {56'd0, tx_byte0};   // Should be 'H' = 0x48
    assign o_r2 = {56'd0, tx_byte1};   // Should be 'i' = 0x69
    assign o_r3 = dbg_r3;              // LSR value
    assign o_pass = tx_byte0 == 8'h48 && tx_byte1 == 8'h69;
}

#[test(test_uart)]
module test_uart {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_uart_harness (
        clk: clk, rst: rst,
        o_pass: pass, o_r1: r1, o_r2: r2, o_r3: r3,
    );

    initial {
        rst.assert(clk);
        clk.next(500);
        $display(r1, r2, r3, pass);
        $assert(pass, "UART TX should output 'H' then 'i'");
        $display("UART test passed");
        $finish();
    }
}
