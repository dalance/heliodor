// Integration test: FADD.D and FSUB.D through CPU pipeline
// Test: 5.0 + 5.0 = 10.0, 5.0 - (-5.0) = 10.0
module test_fp_addsub_harness (
    clk    : input  clock    ,
    rst    : input  reset    ,
    o_pass : output logic     ,
    o_r1   : output logic<64>,
    o_r2   : output logic<64>,
    o_r3   : output logic<64>,
) {
    var imem_addr : logic<64>;
    var imem_rdata: logic<32>;
    var imem_ren  : logic;
    var dmem_addr : logic<64>;
    var dmem_wdata: logic<64>;
    var dmem_rdata: logic<64>;
    var dmem_wen  : logic;
    var dmem_ren  : logic;
    var dmem_wstrb: logic<8>;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>;
    var dbg_pass  : logic;
    var dbg_r1    : logic<64>;
    var dbg_r2    : logic<64>;
    var dbg_r3    : logic<64>;

    inst dut: heliodor_top (
        clk, rst,
        o_imem_addr  : imem_addr     ,
        i_imem_rdata : imem_rdata    ,
        o_imem_ren   : imem_ren      ,
        o_dmem_addr  : dmem_addr     ,
        o_dmem_wdata : dmem_wdata    ,
        i_dmem_rdata : dmem_rdata    ,
        o_dmem_wen   : dmem_wen      ,
        o_dmem_ren   : dmem_ren      ,
        o_dmem_wstrb : dmem_wstrb    ,
        o_dbg_regs   : dbg_regs      ,
        o_dbg_pc     : dbg_pc        ,
        o_dbg_pass   : dbg_pass      ,
        o_dbg_r1     : dbg_r1        ,
        o_dbg_r2     : dbg_r2        ,
        o_dbg_r3     : dbg_r3        ,
        i_ext_irq    : 32'd0        ,
    );

    // Simple data memory (256 bytes = 32 doublewords)
    var mem: logic<64> [32];
    always_ff (clk, rst) {
        if_reset { for i: i32 in 0..32 { mem[i] = 64'd0; } }
        else if dmem_wen { mem[dmem_addr[7:3]] = dmem_wdata; }
    }
    assign dmem_rdata = mem[dmem_addr[7:3]];

    // Test program:
    //   x1 = 0x100 (data base address)
    //   Store 5.0 to mem[0x100], -5.0 to mem[0x108]
    //   FLD f1, 0(x1)  → f1 = 5.0
    //   FLD f2, 8(x1)  → f2 = -5.0
    //   FADD.D f3, f1, f1  → f3 = 10.0
    //   FSUB.D f4, f1, f2  → f4 = 5.0-(-5.0) = 10.0
    //   FSD f3, 16(x1) → mem[0x110]
    //   FSD f4, 24(x1) → mem[0x118]
    //   LD x2, 16(x1)  → x2 = FADD result (expect 10.0 = 0x4024000000000000)
    //   LD x3, 24(x1)  → x3 = FSUB result (expect 10.0 = 0x4024000000000000)
    always_comb {
        case imem_addr[7:0] {
            // x1 = 0x100
            8'h00: imem_rdata = 32'h10000093; // ADDI x1, x0, 0x100
            8'h04: imem_rdata = 32'h00000013; // NOP
            8'h08: imem_rdata = 32'h00000013;
            8'h0C: imem_rdata = 32'h00000013;
            // x2 = 5.0 (0x4014000000000000)
            8'h10: imem_rdata = 32'h40140137; // LUI x2, 0x40140
            8'h14: imem_rdata = 32'h00000013;
            8'h18: imem_rdata = 32'h00000013;
            8'h1C: imem_rdata = 32'h00000013;
            8'h20: imem_rdata = 32'h02011113; // SLLI x2, x2, 32
            8'h24: imem_rdata = 32'h00000013;
            8'h28: imem_rdata = 32'h00000013;
            8'h2C: imem_rdata = 32'h00000013;
            // SD x2, 0(x1) → mem[0x100] = 5.0
            8'h30: imem_rdata = 32'h0020B023; // SD x2, 0(x1)
            8'h34: imem_rdata = 32'h00000013;
            8'h38: imem_rdata = 32'h00000013;
            8'h3C: imem_rdata = 32'h00000013;
            // x3 = -5.0 (0xC014000000000000)
            8'h40: imem_rdata = 32'hC01401B7; // LUI x3, 0xC0140
            8'h44: imem_rdata = 32'h00000013;
            8'h48: imem_rdata = 32'h00000013;
            8'h4C: imem_rdata = 32'h00000013;
            8'h50: imem_rdata = 32'h02019193; // SLLI x3, x3, 32
            8'h54: imem_rdata = 32'h00000013;
            8'h58: imem_rdata = 32'h00000013;
            8'h5C: imem_rdata = 32'h00000013;
            // SD x3, 8(x1) → mem[0x108] = -5.0
            8'h60: imem_rdata = 32'h0030B423; // SD x3, 8(x1)
            8'h64: imem_rdata = 32'h00000013;
            8'h68: imem_rdata = 32'h00000013;
            8'h6C: imem_rdata = 32'h00000013;
            // FLD f1, 0(x1) → f1 = 5.0
            8'h70: imem_rdata = 32'h0000B087; // FLD f1, 0(x1)
            8'h74: imem_rdata = 32'h00000013;
            8'h78: imem_rdata = 32'h00000013;
            8'h7C: imem_rdata = 32'h00000013;
            // FLD f2, 8(x1) → f2 = -5.0
            8'h80: imem_rdata = 32'h0080B107; // FLD f2, 8(x1)
            8'h84: imem_rdata = 32'h00000013;
            8'h88: imem_rdata = 32'h00000013;
            8'h8C: imem_rdata = 32'h00000013;
            // FADD.D f3, f1, f1 → f3 = 5.0 + 5.0 = 10.0
            8'h90: imem_rdata = 32'h021081D3; // FADD.D f3, f1, f1
            8'h94: imem_rdata = 32'h00000013;
            8'h98: imem_rdata = 32'h00000013;
            8'h9C: imem_rdata = 32'h00000013;
            // FSUB.D f4, f1, f2 → f4 = 5.0 - (-5.0) = 10.0
            8'hA0: imem_rdata = 32'h0A208253; // FSUB.D f4, f1, f2
            8'hA4: imem_rdata = 32'h00000013;
            8'hA8: imem_rdata = 32'h00000013;
            8'hAC: imem_rdata = 32'h00000013;
            // FSD f3, 16(x1) → mem[0x110]
            8'hB0: imem_rdata = 32'h0030B827; // FSD f3, 16(x1)
            8'hB4: imem_rdata = 32'h00000013;
            8'hB8: imem_rdata = 32'h00000013;
            8'hBC: imem_rdata = 32'h00000013;
            // FSD f4, 24(x1) → mem[0x118]
            8'hC0: imem_rdata = 32'h0040BC27; // FSD f4, 24(x1)
            8'hC4: imem_rdata = 32'h00000013;
            8'hC8: imem_rdata = 32'h00000013;
            8'hCC: imem_rdata = 32'h00000013;
            // LD x2, 16(x1) → x2 = FADD result
            8'hD0: imem_rdata = 32'h0100B103; // LD x2, 16(x1)
            8'hD4: imem_rdata = 32'h00000013;
            8'hD8: imem_rdata = 32'h00000013;
            8'hDC: imem_rdata = 32'h00000013;
            // LD x3, 24(x1) → x3 = FSUB result
            8'hE0: imem_rdata = 32'h0180B183; // LD x3, 24(x1)
            8'hE4: imem_rdata = 32'h00000013;
            8'hE8: imem_rdata = 32'h00000013;
            8'hEC: imem_rdata = 32'h00000013;
            // Loop
            8'hF0: imem_rdata = 32'h0000006F; // JAL x0, 0 (infinite loop)
            default: imem_rdata = 32'h00000013;
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // Both FADD and FSUB results should be 10.0 = 0x4024000000000000
    assign o_pass = dbg_r2 == 64'h4024000000000000
                 && dbg_r3 == 64'h4024000000000000;
}

#[test(test_fp_addsub)]
module test_fp_addsub {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_fp_addsub_harness (
        clk    : clk  ,
        rst    : rst  ,
        o_pass : pass ,
        o_r1   : r1   ,
        o_r2   : r2   ,
        o_r3   : r3   ,
    );

    initial {
        rst.assert(clk);
        clk.next(500);
        $display(r1, r2, r3, pass);
        $assert(pass, "FADD.D/FSUB.D integration test failed");
        $display("FADD.D/FSUB.D integration test passed");
        $finish();
    }
}
