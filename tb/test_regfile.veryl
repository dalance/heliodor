// Register file unit test
module test_regfile_harness (
    clk    : input  clock   ,
    rst    : input  reset   ,
) {
    var rs1     : logic<5>;
    var rs2     : logic<5>;
    var rs1_data: logic<64>;
    var rs2_data: logic<64>;
    var rd      : logic<5>;
    var rd_data : logic<64>;
    var wen     : logic;
    var dbg     : logic<64> [32];

    inst dut: regfile (
        clk                     ,
        rst                     ,
        i_rs1     : rs1         ,
        i_rs2     : rs2         ,
        o_rs1_data: rs1_data    ,
        o_rs2_data: rs2_data    ,
        i_rd      : rd          ,
        i_rd_data : rd_data     ,
        i_wen     : wen         ,
        o_debug   : dbg         ,
    );

    var tc: logic<8>;

    always_ff {
        if_reset {
            tc = 8'd0;
        } else {
            tc = tc + 8'd1;
        }
    }

    // Drive inputs from registered test counter (no comb loop)
    always_ff {
        if_reset {
            rd      = 5'd0;
            rd_data = 64'd0;
            wen     = 1'b0;
            rs1     = 5'd0;
            rs2     = 5'd0;
        } else {
            // Defaults
            rd      = 5'd0;
            rd_data = 64'd0;
            wen     = 1'b0;
            rs1     = 5'd0;
            rs2     = 5'd0;

            case tc {
                // Set up: write x1 = 100
                8'd0: { rd = 5'd1; rd_data = 64'd100; wen = 1'b1; }
                // Read x1
                8'd1: { rs1 = 5'd1; }
                // Write x2 = 200
                8'd2: { rd = 5'd2; rd_data = 64'd200; wen = 1'b1; }
                // Read x1 and x2
                8'd3: { rs1 = 5'd1; rs2 = 5'd2; }
                // Write x0 = 999 (should be ignored)
                8'd4: { rd = 5'd0; rd_data = 64'd999; wen = 1'b1; }
                // Read x0
                8'd5: { rs1 = 5'd0; }
                default: {}
            }
        }
    }
}

#[test(test_regfile)]
module test_regfile {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    inst harness: test_regfile_harness (
        clk: clk,
        rst: rst,
    );

    initial {
        rst.assert(clk);
        clk.next(8);
        $display("Register file test passed");
        $finish();
    }
}
