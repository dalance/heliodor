// Integration test for CSR read/write instructions
module test_core_csr_harness (
    clk   : input  clock    ,
    rst   : input  reset    ,
    o_pass: output logic    ,
    o_r1  : output logic<64>,
    o_r2  : output logic<64>,
    o_r3  : output logic<64>,
) {
    var imem_addr : logic<64>     ;
    var imem_rdata: logic<32>     ;
    var imem_ren  : logic         ;
    var dmem_addr : logic<64>     ;
    var dmem_wdata: logic<64>     ;
    var dmem_rdata: logic<64>     ;
    var dmem_wen  : logic         ;
    var dmem_ren  : logic         ;
    var dmem_wstrb: logic<8>      ;
    var dbg_regs  : logic<64> [32];
    var dbg_pc    : logic<64>     ;
    var dbg_pass  : logic         ;
    var dbg_r1    : logic<64>     ;
    var dbg_r2    : logic<64>     ;
    var dbg_r3    : logic<64>     ;
    var _iptw_addr: logic<64>     ;
    var _iptw_req : logic         ;

    inst dut: heliodor_top (
        clk                        ,
        rst                        ,
        o_imem_addr    : imem_addr ,
        i_imem_rdata   : imem_rdata,
        o_imem_ren     : imem_ren  ,
        o_iptw_addr    : _iptw_addr,
        o_iptw_req     : _iptw_req ,
        i_iptw_rdata   : 64'd0     ,
        i_uart_rx_data : 8'd0      ,
        i_uart_rx_valid: 1'b0      ,
        o_dmem_addr    : dmem_addr ,
        o_dmem_wdata   : dmem_wdata,
        i_dmem_rdata   : dmem_rdata,
        o_dmem_wen     : dmem_wen  ,
        o_dmem_ren     : dmem_ren  ,
        o_dmem_wstrb   : dmem_wstrb,
        o_dbg_regs     : dbg_regs  ,
        o_dbg_pc       : dbg_pc    ,
        o_dbg_pass     : dbg_pass  ,
        o_dbg_r1       : dbg_r1    ,
        o_dbg_r2       : dbg_r2    ,
        o_dbg_r3       : dbg_r3    ,
        i_ext_irq      : 32'd0     ,
    );

    assign dmem_rdata = 64'd0;

    // Program: test CSR read/write
    //   0x00: ADDI   x1, x0, 0x100   -> x1 = 0x100 (trap vector address)
    //   0x04: NOP                     -> wait for x1 writeback
    //   0x08: NOP
    //   0x0C: NOP
    //   0x10: CSRRW  x2, mtvec, x1   -> mtvec = x1 = 0x100, x2 = old mtvec (0)
    //   0x14: NOP
    //   0x18: NOP
    //   0x1C: NOP
    //   0x20: CSRRS  x3, mtvec, x0   -> x3 = mtvec (0x100), mtvec unchanged
    //   0x24+: NOP
    //
    // Encoding:
    //   ADDI x1, x0, 0x100:  0x10000093
    //   CSRRW x2, mtvec(0x305), x1:  0x30509173
    //   CSRRS x3, mtvec(0x305), x0:  0x305021F3
    always_comb {
        case imem_addr[7:0] {
            8'h00  : imem_rdata = 32'h10000093; // ADDI x1, x0, 0x100
            8'h04  : imem_rdata = 32'h00000013; // NOP
            8'h08  : imem_rdata = 32'h00000013; // NOP
            8'h0C  : imem_rdata = 32'h00000013; // NOP
            8'h10  : imem_rdata = 32'h30509173; // CSRRW x2, mtvec, x1
            8'h14  : imem_rdata = 32'h00000013; // NOP
            8'h18  : imem_rdata = 32'h00000013; // NOP
            8'h1C  : imem_rdata = 32'h00000013; // NOP
            8'h20  : imem_rdata = 32'h305021F3; // CSRRS x3, mtvec, x0
            default: imem_rdata = 32'h00000013; // NOP
        }
    }

    assign o_r1 = dbg_r1;
    assign o_r2 = dbg_r2;
    assign o_r3 = dbg_r3;
    // x1=0x100, x2=0 (old mtvec), x3=0x100 (new mtvec)
    assign o_pass = dbg_r1 == 64'h100 && dbg_r2 == 64'd0 && dbg_r3 == 64'h100;
}

#[test(test_core_csr)]
module test_core_csr {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen;

    var pass: logic    ;
    var r1  : logic<64>;
    var r2  : logic<64>;
    var r3  : logic<64>;

    inst harness: test_core_csr_harness (
        clk   : clk ,
        rst   : rst ,
        o_pass: pass,
        o_r1  : r1  ,
        o_r2  : r2  ,
        o_r3  : r3  ,
    );

    initial {
        rst.assert(clk);
        clk.next  (45);
        $display  (r1, r2, r3, pass);
        $assert   (pass, "CSR register values mismatch");
        $display  ("CSR integration test passed");
        $finish   ();
    }
}
