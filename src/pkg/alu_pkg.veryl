// ALU operation definitions
pub package alu_pkg {
    enum AluOp: logic<4> {
        ADD  = 4'd0,
        SUB  = 4'd1,
        SLL  = 4'd2,
        SLT  = 4'd3,
        SLTU = 4'd4,
        XOR  = 4'd5,
        SRL  = 4'd6,
        SRA  = 4'd7,
        OR   = 4'd8,
        AND  = 4'd9,
        ADDW = 4'd10,
        SUBW = 4'd11,
        SLLW = 4'd12,
        SRLW = 4'd13,
        SRAW = 4'd14,
    }
}
