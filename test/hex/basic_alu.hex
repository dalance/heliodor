// Basic ALU test: compute 0x12345000 + 0x678 = 0x12345678
// Expected: x1 = 0x12345678, x2 = 0x12345678 + 1 = 0x12345679
// addr  instruction        asm
// 0x00  LUI x1, 0x12345    x1 = 0x12345000
123450B7
// 0x04  NOP (pipeline)
00000013
00000013
00000013
// 0x10  ADDI x1, x1, 0x678 x1 = 0x12345678
67808093
// 0x14  NOP
00000013
00000013
00000013
// 0x20  ADDI x2, x1, 1     x2 = x1 + 1 = 0x12345679
00108113
// 0x24  NOP
00000013
00000013
00000013
// 0x30  JAL x0, 0           infinite loop
0000006F
